---
---

<section id="about" class="section-fullscreen relative flex items-center overflow-hidden">
  <div class="relative z-10 w-full max-w-5xl mx-auto px-6 md:px-12 lg:px-[7%]">
    <!-- Section number -->
    <div class="cin-reveal flex items-center gap-4 mb-10 md:mb-14">
      <span class="text-[10px] tracking-[0.3em] text-white/20 font-mono">01</span>
      <div class="w-8 h-px bg-white/10"></div>
      <span class="text-[10px] tracking-[0.2em] text-white/20 uppercase">About</span>
    </div>

    <!-- Main text with mask reveal -->
    <div class="space-y-1 mb-12 md:mb-16">
      <p class="mask-reveal text-lg md:text-2xl lg:text-3xl leading-[1.6] font-light">
        SIer・コンサルティングファームを経て、
      </p>
      <p class="mask-reveal text-lg md:text-2xl lg:text-3xl leading-[1.6] font-light">
        大規模プラットフォームの設計・構築・運用に
      </p>
      <p class="mask-reveal text-lg md:text-2xl lg:text-3xl leading-[1.6] font-light">
        一貫して携わってきました。
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-8 md:gap-16">
      <!-- Left: description -->
      <div class="space-y-5">
        <p class="mask-reveal text-sm leading-[1.8] text-white/40 font-light">
          現在はスタートアップのCTOとして、AIエージェント基盤やSaaS製品のアーキテクチャ設計から実装・運用まで、プロダクト開発を一気通貫で手がけています。
        </p>
        <p class="mask-reveal text-sm leading-[1.8] text-white/40 font-light">
          業務の傍ら、個人開発でもブロックチェーン上のトレーディングBot、不動産リスク分析AI、ペットケアPWAなど——技術の限界を探る挑戦を続けています。
        </p>
      </div>

      <!-- Right: profile -->
      <div class="cin-reveal cin-delay-1">
        <div class="flex items-center gap-4 mb-6">
          <div class="w-12 h-12 rounded-full overflow-hidden border border-white/10 relative">
            <!-- Animated ring -->
            <div class="absolute inset-[-2px] rounded-full border border-white/[0.06] animate-spin" style="animation-duration: 12s;"></div>
            <picture>
              <source srcset="/images/profile.avif" type="image/avif" />
              <img src="/images/profile.jpg" alt="Kimura Shun" width="48" height="48" class="w-full h-full object-cover" loading="lazy" />
            </picture>
          </div>
          <div>
            <p class="font-heading text-sm font-medium">Kimura Shun</p>
            <p class="text-[10px] text-white/25 tracking-[0.1em] mt-0.5">CTO / Full-Stack Engineer</p>
          </div>
        </div>
        <!-- Stats with animated count-up feel -->
        <div class="flex gap-10">
          <div class="stat-block group">
            <p class="font-heading text-2xl md:text-3xl font-light transition-colors duration-500 group-hover:text-[#00f0ff]/60">15+</p>
            <p class="text-[10px] tracking-[0.15em] text-white/25 uppercase mt-1">Projects</p>
          </div>
          <div class="stat-block group">
            <p class="font-heading text-2xl md:text-3xl font-light transition-colors duration-500 group-hover:text-[#8b5cf6]/60">7+</p>
            <p class="text-[10px] tracking-[0.15em] text-white/25 uppercase mt-1">Products</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
