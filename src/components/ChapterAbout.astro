---
const career = [
  { period: '2017 — 2023', role: 'SIer', description: '大規模基幹システムの設計・開発。Java/Oracleを中心にウォーターフォール開発で堅牢なシステム構築の基礎を培う。' },
  { period: '2023 — Now', role: 'コンサルティングファーム', description: 'DX推進プロジェクトのテックリード。クラウドマイグレーション、マイクロサービス化、CI/CD基盤構築を主導。' },
  { period: '2025 — Now', role: 'スタートアップ CPO兼CTO', description: 'AIエージェント基盤・SaaS製品のアーキテクチャ設計から実装・運用まで、プロダクト開発を一気通貫で推進。' },
];

const philosophy = [
  { label: 'Architecture', text: '「動くコード」ではなく「進化できるアーキテクチャ」を設計する' },
  { label: 'Ownership', text: 'フロントエンドからインフラまで、一人で全レイヤーを持てる強みを武器にする' },
  { label: 'AI-Native', text: 'AIを道具として使うだけでなく、AIと協働する開発プロセスを設計する' },
];
---

<section id="about" class="relative py-32 md:py-40 overflow-hidden">
  <div class="relative z-10 w-full max-w-6xl mx-auto px-6 md:px-12 lg:px-[7%]">
    <!-- Section number -->
    <div class="cin-reveal flex items-center gap-4 mb-10 md:mb-14">
      <span class="text-[10px] tracking-[0.3em] text-white/50 font-mono">01</span>
      <div class="w-8 h-px bg-white/10"></div>
      <span class="text-[10px] tracking-[0.2em] text-white/50 uppercase">About</span>
    </div>

    <!-- Main statement -->
    <div class="mb-16 md:mb-20 max-w-3xl">
      <p class="mask-reveal text-xl md:text-3xl lg:text-4xl leading-[1.5] font-light">
        SIerからコンサルティングファーム、そしてスタートアップCPO兼CTOへ——
        <span class="text-white/90">プロダクトの全レイヤー</span>を
        一人で設計・構築できるエンジニアになりました。
      </p>
    </div>

    <!-- Two column: Profile + Philosophy -->
    <div class="grid md:grid-cols-5 gap-12 md:gap-16 mb-20 md:mb-28">
      <!-- Left: Profile card (2 cols) -->
      <div class="md:col-span-2 cin-reveal">
        <div class="p-6 rounded-lg border border-white/[0.09] bg-white/[0.02]">
          <div class="flex items-center gap-4 mb-6">
            <div class="w-14 h-14 rounded-full overflow-hidden border border-white/10 relative flex-shrink-0">
              <div class="absolute inset-[-2px] rounded-full border border-white/[0.09] animate-spin" style="animation-duration: 12s;"></div>
              <picture>
                <source srcset="/images/profile.avif" type="image/avif" />
                <img src="/images/profile.jpg" alt="Kimura Shun" width="56" height="56" class="w-full h-full object-cover" loading="lazy" />
              </picture>
            </div>
            <div>
              <p class="font-heading text-base font-medium">Kimura Shun</p>
              <p class="text-[11px] text-white/50 tracking-[0.08em] mt-0.5">CPO兼CTO / Full-Stack Engineer</p>
            </div>
          </div>
          <p class="text-sm text-white/50 leading-[1.8] font-light mb-6">
            現在はスタートアップのCPO兼CTOとして、AIエージェント基盤やSaaS製品のプロダクト開発を推進。業務の傍ら、個人開発でもブロックチェーンBot、不動産リスク分析AI、ペットケアPWAなど多様な領域に挑戦。
          </p>
          <div class="flex gap-4">
            <a href="https://github.com/XxxKMSxxX" target="_blank" rel="noopener noreferrer" class="text-[11px] tracking-[0.1em] text-white/40 hover:text-white/60 transition-colors duration-400 uppercase flex items-center gap-1.5">
              <span class="i-simple-icons-github text-sm"></span> GitHub
            </a>
            <a href="https://www.linkedin.com/in/%E4%BF%8A-%E6%9C%A8%E6%9D%91-104821375/" target="_blank" rel="noopener noreferrer" class="text-[11px] tracking-[0.1em] text-white/40 hover:text-white/60 transition-colors duration-400 uppercase flex items-center gap-1.5">
              <span class="i-simple-icons-linkedin text-sm"></span> LinkedIn
            </a>
          </div>
        </div>
      </div>

      <!-- Right: Philosophy (3 cols) -->
      <div class="md:col-span-3 space-y-6">
        <h3 class="cin-reveal text-xs tracking-[0.2em] text-white/50 uppercase mb-6">Engineering Philosophy</h3>
        {philosophy.map((item, i) => (
          <div class="cin-reveal group" style={`transition-delay: ${i * 0.1}s;`}>
            <div class="flex items-start gap-4 p-4 rounded-lg transition-all duration-500 hover:bg-white/[0.02]">
              <span class="text-[10px] tracking-[0.2em] text-white/25 uppercase font-mono mt-1 flex-shrink-0 w-24">{item.label}</span>
              <p class="text-sm text-white/40 leading-[1.8] font-light group-hover:text-white/60 transition-colors duration-500">{item.text}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Career Timeline -->
    <div>
      <h3 class="cin-reveal text-xs tracking-[0.2em] text-white/50 uppercase mb-8">Career</h3>
      <div class="space-y-0">
        {career.map((item, i) => (
          <div class="cin-reveal">
            <div class="line-h w-full"></div>
            <div class="grid md:grid-cols-12 gap-4 md:gap-8 py-6 md:py-8 group hover:bg-white/[0.01] transition-colors duration-500 rounded-sm px-2 -mx-2">
              <div class="md:col-span-3">
                <span class="text-xs text-white/50 tracking-[0.1em] font-mono">{item.period}</span>
              </div>
              <div class="md:col-span-3">
                <span class="text-sm text-white/60 font-medium">{item.role}</span>
              </div>
              <div class="md:col-span-6">
                <p class="text-sm text-white/50 leading-[1.7] font-light group-hover:text-white/65 transition-colors duration-500">{item.description}</p>
              </div>
            </div>
          </div>
        ))}
        <div class="line-h w-full"></div>
      </div>
    </div>
  </div>
</section>
