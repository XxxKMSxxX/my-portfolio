const devPractices = [
  {
    title: 'Infrastructure as Code',
    icon: 'i-simple-icons-terraform',
    items: [
      'TerraformでAWSインフラ（VPC / ECS / IAM等）をコード管理',
      'Kubernetes + Helm + ArgoCD で GitOps 継続的デリバリー',
      'Docker Composeでアプリ + 監視基盤の開発環境を統一',
      'AWS ECS / Vercel / Amplify を用途に応じて使い分け',
    ],
  },
  {
    title: 'Testing & Quality',
    icon: 'i-simple-icons-vitest',
    items: [
      '850+テストで取引ロジックの網羅的な振る舞い検証',
      'Vitest + Playwright + Lighthouse CIの3層テスト戦略',
      'mypy (strict) / Clippy / ESLint による言語横断の静的解析',
      'GitHub Actions で PR ごとにCI自動実行',
    ],
