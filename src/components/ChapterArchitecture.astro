const devPractices = [
  {
    title: 'Infrastructure as Code',
    icon: 'i-simple-icons-terraform',
    items: [
      'Terraform (HCL) でAWSインフラをコード管理（Cryptra-Infra, TradeDataProcessor）',
      'Kubernetes + Helm + helmfileでコンテナオーケストレーション（k8s-infrastructure）',
      'Docker Composeで開発環境統一（bitflush: offchain + Prometheus + Grafana）',
      'AWS ECS / Amplify / Vercel を用途別に使い分け',
    ],
  },
  {
    title: 'Testing & Quality',
    icon: 'i-simple-icons-vitest',
    items: [
      'bitflush: 854テストでアービトラージロジックの網羅的検証',
      'PETTAS: Vitest + Playwright + Lighthouse CIの3層テスト',
      'sns-shared-lib: Vitest + coverage-v8で品質担保',
      'mypy (strict) / Clippy / ESLint による静的解析徹底',
    ],
  },
  {
    title: 'Monitoring & Security',
    icon: 'i-simple-icons-prometheus',
    items: [
      'Prometheus + Grafanaでbitflushのメトリクスリアルタイム監視',
      'Sentry + Vercel Analyticsでフロントエンドエラー追跡（PETTAS）',
      'keypair zeroizeによるオンチェーン秘密鍵のメモリ安全対策',
      'jemalloc（tikv-jemallocator）でメモリフラグメンテーション対策',
    ],
  },
