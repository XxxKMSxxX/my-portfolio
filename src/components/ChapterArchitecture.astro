---

<section id="architecture" class="relative py-32 md:py-40 overflow-hidden">
  <div class="relative z-10 w-full max-w-6xl mx-auto px-6 md:px-12">
    <!-- Section number -->
    <div class="cin-reveal flex items-center gap-4 mb-10 md:mb-14">
      <span class="text-[10px] tracking-[0.3em] text-white/50 font-mono">03</span>
      <div class="w-8 h-px bg-white/10"></div>
      <span class="text-[10px] tracking-[0.2em] text-white/50 uppercase">Architecture</span>
    </div>

    <!-- Title -->
    <div class="cin-reveal mb-6 md:mb-8">
      <h2 class="mask-reveal text-[6vw] md:text-[3.5vw] lg:text-[2.8vw] leading-[1.4] tracking-[0.01em] font-light">
        設計の<span class="font-serif italic">引き出し</span>
      </h2>
    </div>
    <p class="cin-reveal cin-delay-1 mask-reveal text-sm text-white/50 font-light leading-relaxed max-w-xl mb-16 md:mb-24">
      「どの技術を使うか」より「どう設計するか」がプロダクトの寿命を決める。<br />
      実際に運用してきたアーキテクチャパターンと開発プラクティスです。
    </p>

    <!-- Architecture patterns -->
    <div class="space-y-6 md:space-y-8 mb-24 md:mb-32">
      {architecturePatterns.map((pattern) => (
        <div class="cin-reveal arch-card group">
          <div class="line-h w-full"></div>
          <div class="py-6 md:py-10 px-2 md:px-6 -mx-2 md:-mx-6 rounded-lg transition-all duration-500 hover:bg-white/[0.015]">
            <div class="grid md:grid-cols-12 gap-4 md:gap-8">
              <!-- Title col -->
              <div class="md:col-span-4">
                <div class="flex items-center gap-2.5 mb-2">
                  <div class="w-2 h-2 rounded-full flex-shrink-0" style={`background: ${pattern.accent};`}></div>
                  <h3 class="font-heading text-base md:text-lg font-medium leading-tight">{pattern.title}</h3>
                </div>
                <p class="text-[11px] tracking-[0.05em] text-white/50 mb-3">{pattern.context}</p>
                <p class="text-[13px] text-white/50 leading-[1.7] font-light group-hover:text-white/65 transition-colors duration-500">
                  {pattern.description}
                </p>
              </div>
              <!-- Details col -->
              <div class="md:col-span-8">
                <div class="grid sm:grid-cols-2 gap-x-8 gap-y-2.5 md:pt-1">
                  {pattern.details.map(detail => (
                    <div class="flex items-start gap-2.5">
                      <span class="w-px h-3 mt-1 flex-shrink-0" style={`background: ${pattern.accent}40;`}></span>
                      <p class="text-[12px] text-white/40 leading-[1.6] font-light group-hover:text-white/60 transition-colors duration-500">{detail}</p>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </div>
      ))}
      <div class="line-h w-full"></div>
    </div>

    <!-- Development Practices -->
    <div>
      <h3 class="cin-reveal text-xs tracking-[0.2em] text-white/50 uppercase mb-10">Development Practices</h3>
      <div class="grid md:grid-cols-3 gap-6" data-stagger-parent>
        {devPractices.map(practice => (
          <div class="cin-reveal group p-5 rounded-lg border border-white/[0.07] bg-white/[0.01] hover:bg-white/[0.025] hover:border-white/[0.12] transition-all duration-500" data-stagger-child>
            <div class="flex items-center gap-3 mb-4">
              <span class={`${practice.icon} text-base text-white/50 group-hover:text-white/70 transition-colors duration-500`}></span>
              <h4 class="text-sm font-medium tracking-[0.02em]">{practice.title}</h4>
            </div>
            <ul class="space-y-2.5">
              {practice.items.map(item => (
                <li class="flex items-start gap-2 text-[12px] text-white/40 leading-[1.6] font-light group-hover:text-white/60 transition-colors duration-500">
                  <span class="w-1 h-1 rounded-full bg-white/10 mt-1.5 flex-shrink-0"></span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
