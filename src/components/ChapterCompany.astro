---
const awards = [
  { year: '2026', title: 'JETRO J-StarX 採択', detail: 'シンガポール拠点グローバル展開' },
  { year: '2025', title: 'Polar Bear Pitching TOKYO', detail: 'SILVER AWARD（全体第2位）' },
  { year: '2025', title: 'TechCrunch Disrupt', detail: '出展・登壇' },
  { year: '2025', title: '港区スタートアップ認定', detail: '' },
  { year: '2025', title: 'X-HUB TOKYO 採択', detail: '' },
];
---

<section id="company" class="relative min-h-screen py-40 px-6">
  <!-- Chapter title card -->
  <div class="max-w-6xl mx-auto mb-20">
    <div class="chapter-card flex items-center gap-6 mb-16">
      <span class="font-heading text-7xl md:text-9xl font-bold text-white/[0.03]">02</span>
      <div>
        <div class="line-reveal w-12 h-px bg-[#8b5cf6] mb-3"></div>
        <span class="text-[10px] tracking-[0.4em] uppercase text-[#8b5cf6]">Vision</span>
      </div>
    </div>

    <!-- Company intro -->
    <div class="mb-24">
      <div class="cin-reveal flex items-center gap-4 mb-6">
        <span class="text-sm text-white/30 tracking-wider">株式会社AI光</span>
        <span class="text-white/10">|</span>
        <span class="text-sm text-white/30">AI Hikari, Inc.</span>
        <span class="text-white/10">|</span>
        <span class="text-sm text-white/30">2025 — Tokyo</span>
      </div>

      <h2 class="cin-reveal cin-delay-1 font-heading text-3xl md:text-6xl font-bold leading-tight mb-8 max-w-4xl">
        未来を読み、判断を動かし、<br />
        <span class="bg-gradient-to-r from-[#8b5cf6] to-[#f472b6] bg-clip-text" style="color: transparent; -webkit-background-clip: text;">
          社会を前へ。
        </span>
      </h2>

      <p class="cin-reveal cin-delay-2 text-white/40 max-w-2xl leading-relaxed">
        サプライチェーンの意思決定をAIエージェントで変革する——。
        需要予測の高度化で過剰生産・廃棄を減らし、経済効率と環境負荷軽減の両立を実現する世界を目指しています。
      </p>
    </div>

    <!-- OVERSEE product -->
    <div class="cin-reveal cin-delay-1 mb-24">
      <div class="relative p-8 md:p-12 rounded-2xl border border-white/5 bg-white/[0.01] overflow-hidden">
        <!-- Background glow -->
        <div class="absolute top-0 right-0 w-64 h-64 bg-[#8b5cf6]/5 rounded-full blur-[100px] pointer-events-none"></div>
        <div class="absolute bottom-0 left-0 w-48 h-48 bg-[#00f0ff]/5 rounded-full blur-[80px] pointer-events-none"></div>

        <div class="relative">
          <div class="flex items-center gap-3 mb-4">
            <span class="font-heading text-2xl md:text-3xl font-bold">OVERSEE</span>
            <span class="text-[10px] tracking-wider uppercase text-[#8b5cf6] border border-[#8b5cf6]/20 px-2 py-0.5 rounded-full bg-[#8b5cf6]/5">
              Flagship
            </span>
          </div>
          <p class="text-white/40 max-w-2xl leading-relaxed mb-8">
            自然言語で問いかけるだけで、世界中の市場データと高精度な予測モデルを活用した需要予測から、
            意思決定に必要な計画資料の自動生成まで——サプライチェーンの構造課題を根本から解決する次世代予測AIエージェント。
          </p>

          <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
            {[
              { label: 'Trade Navigator', desc: '国際貿易AIプラットフォーム' },
              { label: 'Clearly', desc: '化学品規制クリアランス判定' },
              { label: 'Procurement', desc: 'AI調達マッチング' },
              { label: 'Agent Platform', desc: '自律実行AIエージェント基盤' },
            ].map(product => (
              <div class="group">
                <p class="text-sm font-medium text-white/70 group-hover:text-[#00f0ff] transition-colors duration-300 mb-1">
                  {product.label}
                </p>
                <p class="text-xs text-white/25">{product.desc}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>

    <!-- Awards -->
    <div>
      <p class="cin-reveal text-[10px] tracking-[0.4em] uppercase text-white/30 mb-8">Awards & Recognition</p>
      <div class="space-y-0">
        {awards.map((award, idx) => (
          <div class={`cin-reveal cin-delay-${idx + 1} group flex items-baseline gap-6 py-4 border-b border-white/5 hover:border-[#8b5cf6]/20 transition-colors duration-500`}>
            <span class="text-xs text-white/20 font-mono w-12 flex-shrink-0">{award.year}</span>
            <span class="text-sm md:text-base text-white/60 group-hover:text-white/80 transition-colors duration-300">
              {award.title}
            </span>
            {award.detail && (
              <span class="text-xs text-white/20 hidden md:inline">{award.detail}</span>
            )}
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
