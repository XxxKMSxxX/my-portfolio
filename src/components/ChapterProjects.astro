<section id="projects" class="relative py-40 px-6">
  <!-- Chapter title card -->
  <div class="max-w-6xl mx-auto mb-20">
    <div class="chapter-card flex items-center gap-6 mb-16">
      <span class="font-heading text-7xl md:text-9xl font-bold text-white/[0.03]">03</span>
      <div>
        <div class="line-reveal w-12 h-px bg-[#f472b6] mb-3"></div>
        <span class="text-[10px] tracking-[0.4em] uppercase text-[#f472b6]">Works</span>
      </div>
    </div>

    <h2 class="cin-reveal font-heading text-3xl md:text-5xl font-bold mb-6">
      Selected Projects
    </h2>
    <p class="cin-reveal cin-delay-1 text-white/35 max-w-xl mb-20">
      プロフェッショナルワークから個人開発まで、技術の可能性に挑み続けるプロジェクト群。
    </p>
  </div>

  <!-- Project list -->
  <div class="max-w-6xl mx-auto space-y-32">
    {projects.map((project, idx) => (
      <article class="cin-reveal group">
        <div class={`grid md:grid-cols-2 gap-8 md:gap-16 items-center ${idx % 2 === 1 ? 'direction-rtl' : ''}`}>
          {/* Visual */}
          <div class={`${idx % 2 === 1 ? 'md:order-2' : ''}`}>
            <div class={`relative aspect-[16/10] rounded-xl overflow-hidden border border-white/5 bg-gradient-to-br ${project.gradient}`}>
              <canvas class="project-3d-canvas w-full h-full" data-color={project.color} data-idx={idx}></canvas>
              <div class="absolute inset-0 bg-gradient-to-t from-[#020202]/60 via-transparent to-transparent"></div>
              {/* Type badge */}
              <div class="absolute top-4 left-4">
                <span
                  class="text-[9px] tracking-[0.2em] uppercase px-2.5 py-1 rounded-full border"
                  style={`color: ${project.color}; border-color: ${project.color}30; background: ${project.color}10;`}
                >
                  {project.type}
                </span>
              </div>
            </div>
          </div>

          {/* Info */}
          <div class={`${idx % 2 === 1 ? 'md:order-1 md:text-right' : ''}`}>
            <span class="text-xs font-mono text-white/15 tracking-wider">0{idx + 1}</span>
            <h3 class="font-heading text-2xl md:text-4xl font-bold mt-2 mb-1 group-hover:text-white transition-colors duration-300" style={`color: ${project.color};`}>
              {project.title}
            </h3>
            <p class="text-sm text-white/40 mb-4">{project.subtitle}</p>
            <p class="text-white/35 text-sm leading-relaxed mb-6">
              {project.description}
            </p>
            <div class={`flex flex-wrap gap-2 ${idx % 2 === 1 ? 'md:justify-end' : ''}`}>
              {project.tags.map(tag => (
                <span
                  class="text-[10px] tracking-wider uppercase px-2.5 py-1 rounded-full border"
                  style={`color: ${project.color}80; border-color: ${project.color}15;`}
                >
                  {tag}
                </span>
              ))}
            </div>
            {project.url && (
              <a
                href={project.url}
                target="_blank"
                rel="noopener noreferrer"
                class={`inline-flex items-center gap-2 mt-4 text-xs tracking-wider uppercase transition-colors duration-300 hover:opacity-80`}
                style={`color: ${project.color};`}
              >
                Visit Site →
              </a>
            )}
          </div>
        </div>
      </article>
    ))}
  </div>
</section>

<script>
  import * as THREE from 'three';

  function initProjectScenes() {
    const canvases = document.querySelectorAll<HTMLCanvasElement>('.project-3d-canvas');

    canvases.forEach((canvas) => {
      const color = canvas.dataset.color ?? '#00f0ff';
      const rect = canvas.getBoundingClientRect();
      if (rect.width === 0) return;

      const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
      renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
      renderer.setSize(rect.width, rect.height);

      const scene = new THREE.Scene();
      const camera = new THREE.PerspectiveCamera(50, rect.width / rect.height, 0.1, 100);
      camera.position.z = 6;

      const group = new THREE.Group();
      scene.add(group);

      // Scattered wireframe shapes
      const shapes = [
        new THREE.IcosahedronGeometry(0.5, 0),
        new THREE.OctahedronGeometry(0.4, 0),
        new THREE.TetrahedronGeometry(0.35, 0),
        new THREE.TorusGeometry(0.3, 0.1, 6, 12),
      ];

      for (let i = 0; i < 8; i++) {
        const geo = shapes[i % shapes.length];
        const edges = new THREE.EdgesGeometry(geo);
        const mat = new THREE.LineBasicMaterial({
          color,
          transparent: true,
          opacity: 0.15 + Math.random() * 0.2,
        });
        const line = new THREE.LineSegments(edges, mat);
        line.position.set(
          (Math.random() - 0.5) * 7,
          (Math.random() - 0.5) * 5,
          (Math.random() - 0.5) * 4,
        );
        line.rotation.set(Math.random() * Math.PI, Math.random() * Math.PI, 0);
        const s = 0.6 + Math.random() * 1.8;
        line.scale.setScalar(s);
        group.add(line);
      }

      // Particles
      const pCount = 100;
      const pGeo = new THREE.BufferGeometry();
      const pPos = new Float32Array(pCount * 3);
      for (let i = 0; i < pCount; i++) {
        pPos[i * 3] = (Math.random() - 0.5) * 10;
        pPos[i * 3 + 1] = (Math.random() - 0.5) * 8;
        pPos[i * 3 + 2] = (Math.random() - 0.5) * 6;
      }
      pGeo.setAttribute('position', new THREE.BufferAttribute(pPos, 3));
      const pMat = new THREE.PointsMaterial({
        color,
        size: 0.03,
        transparent: true,
        opacity: 0.4,
        blending: THREE.AdditiveBlending,
      });
      group.add(new THREE.Points(pGeo, pMat));

      let time = 0;
      let running = false;

      function animate() {
        if (!running) return;
        requestAnimationFrame(animate);
        time += 0.016;

        group.rotation.y = time * 0.08;
        group.rotation.x = Math.sin(time * 0.15) * 0.08;

        group.children.forEach((child, i) => {
          if (child instanceof THREE.LineSegments) {
            child.rotation.x += 0.002;
            child.rotation.y += 0.003;
            child.position.y += Math.sin(time + i) * 0.0008;
          }
        });

        renderer.render(scene, camera);
      }

      const observer = new IntersectionObserver(entries => {
        entries.forEach(entry => {
          running = entry.isIntersecting;
          if (running) animate();
        });
      }, { threshold: 0.05 });
      observer.observe(canvas);

      const resizeObs = new ResizeObserver(entries => {
        for (const entry of entries) {
          const { width, height } = entry.contentRect;
          if (width > 0 && height > 0) {
            camera.aspect = width / height;
            camera.updateProjectionMatrix();
            renderer.setSize(width, height);
          }
        }
      });
      resizeObs.observe(canvas);
    });
  }

  initProjectScenes();
</script>
