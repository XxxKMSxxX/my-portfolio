---

<section id="projects" class="relative py-32 md:py-40">
  <div class="max-w-6xl mx-auto px-6 md:px-12">
    <!-- Section number -->
    <div class="cin-reveal flex items-center gap-4 mb-10 md:mb-14">
      <span class="text-[10px] tracking-[0.3em] text-white/50 font-mono">04</span>
      <div class="w-8 h-px bg-white/10"></div>
      <span class="text-[10px] tracking-[0.2em] text-white/50 uppercase">Projects</span>
    </div>

    <!-- Title + lead -->
    <div class="cin-reveal mb-6 md:mb-8">
      <h2 class="mask-reveal text-[6vw] md:text-[3.5vw] lg:text-[2.8vw] leading-[1.4] tracking-[0.01em] font-light">
        つくってきた<span class="font-serif italic">もの</span>たち
      </h2>
    </div>
    <p class="cin-reveal cin-delay-1 mask-reveal text-sm text-white/50 font-light leading-relaxed max-w-xl mb-16 md:mb-24">
      すべてのプロジェクトでアーキテクチャ選定から実装・運用まで一貫して担当。<br />
      ソースコードはGitHubで公開しています。
    </p>

    <!-- Project list -->
    <div class="space-y-0">
      {projects.map((project, idx) => (
        <article class="project-item group" data-cursor-hover data-mouse-target={project.title} data-accent={project.accent}>
          <div class="line-h w-full"></div>
          <div class="py-8 md:py-12 cin-reveal relative">
            <!-- Hover accent glow -->
            <div
              class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-700 pointer-events-none rounded-lg"
              style={`background: linear-gradient(135deg, ${project.accent}06 0%, transparent 50%);`}
            ></div>

            <div class="relative">
              <!-- Header -->
              <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-2 md:gap-12 mb-4 md:mb-6">
                <div class="flex-1">
                  <div class="flex items-center gap-3 mb-2">
                    <span class="project-num font-heading text-3xl md:text-4xl font-extralight tabular-nums transition-colors duration-500" style="color: rgba(255,255,255,0.06);" data-hover-color={project.accent}>
                      {String(idx + 1).padStart(2, '0')}
                    </span>
                    <div class="w-4 h-px bg-white/10 group-hover:w-8 transition-all duration-500"></div>
                    <span class="text-[10px] tracking-[0.15em] text-white/25 uppercase hidden md:inline">{project.role}</span>
                  </div>
                  <a href={project.url} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 group/title">
                    <h3 class="font-heading text-xl md:text-2xl lg:text-3xl font-medium leading-tight group-hover:text-white transition-colors duration-500">
                      {project.title}
                    </h3>
                    <svg width="14" height="14" viewBox="0 0 10 10" fill="none" class="stroke-current text-white/10 group-hover/title:text-white/40 transition-all duration-400 flex-shrink-0">
                      <path d="M1 1H9M9 1V9M9 1L1 9" stroke-linecap="round" stroke-linejoin="round" stroke-width="1"/>
                    </svg>
                  </a>
                  <p class="text-xs text-white/40 mt-1 tracking-wide group-hover:text-white/60 transition-colors duration-500">{project.subtitle}</p>
                </div>
                <!-- Tags -->
                <div class="flex flex-wrap md:justify-end gap-1.5 mt-2 md:mt-1 md:max-w-xs">
                  {project.tags.map(tag => (
                    <span class="text-[9px] tracking-[0.08em] text-white/25 uppercase px-2 py-0.5 border border-white/[0.07] rounded-sm group-hover:border-white/[0.12] group-hover:text-white/70 transition-all duration-500">
                      {tag}
                    </span>
                  ))}
                </div>
              </div>

              <!-- Body -->
              <div class="grid md:grid-cols-2 gap-4 md:gap-12">
                <p class="text-sm text-white/50 leading-[1.8] font-light group-hover:text-white/70 transition-colors duration-500">
                  {project.description}
                </p>
                <ul class="space-y-2">
                  {project.highlights.map(h => (
                    <li class="flex items-start gap-2.5 text-[12px] text-white/50 font-light group-hover:text-white/70 transition-colors duration-500">
                      <span class="w-1 h-1 rounded-full mt-1.5 flex-shrink-0" style={`background: ${project.accent}50;`}></span>
                      <span>{h}</span>
                    </li>
                  ))}
                </ul>
              </div>

              <!-- Mobile role -->
              <p class="text-[10px] tracking-[0.15em] text-white/25 uppercase mt-4 md:hidden">{project.role}</p>
            </div>
          </div>
        </article>
      ))}
      <div class="line-h w-full"></div>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('.project-item').forEach(item => {
    const num = item.querySelector('.project-num') as HTMLElement;
    const accent = (item as HTMLElement).dataset.accent;
    if (!num || !accent) return;

    item.addEventListener('mouseenter', () => {
      num.style.color = accent + '50';
    });
    item.addEventListener('mouseleave', () => {
      num.style.color = 'rgba(255,255,255,0.06)';
    });
  });
</script>
