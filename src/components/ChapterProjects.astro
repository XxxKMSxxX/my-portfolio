---
const projects = [
  {
    id: 'demand-forecast',
    title: 'Demand Forecast AI Agent',
    subtitle: '需要予測AIエージェントプラットフォーム',
    description: '対話型インターフェースで市場データと予測モデルを統合し、サプライチェーンの意思決定を加速するAIエージェント基盤。',
    tags: ['Next.js', 'FastAPI', 'AWS EKS', 'SageMaker', 'Terraform'],
    accent: '#00f0ff',
  },
  {
    id: 'trade-ai',
    title: 'International Trade AI',
    subtitle: '国際貿易AIプラットフォーム',
    description: 'HSコード分類、関税計算、FTA活用判断、規制チェックをAIが一括処理。国際貿易の複雑な意思決定を秒速に。',
    tags: ['Next.js', 'Turso', 'Claude AI', 'Drizzle ORM'],
    accent: '#8b5cf6',
  },
  {
    id: 'arbitrage',
    title: 'DEX Arbitrage Bot',
    subtitle: 'アトミックアービトラージBot',
    description: '13のDEXを横断するブロックチェーン上のアービトラージBot。Rust × Anchorで構築、Flash Loan・MEV統合。',
    tags: ['Rust', 'Anchor', 'Solana', 'gRPC'],
    accent: '#f472b6',
  },
  {
    id: 'pet-app',
    title: 'Pet Care PWA',
    subtitle: 'ペットケア記録アプリ',
    description: '投薬・通院・健康記録を家族で共有するPWA。AIによる健康レポート自動生成、プッシュ通知でリマインド。',
    tags: ['Next.js', 'Turso', 'Claude AI', 'PWA'],
    accent: '#34d399',
  },
  {
    id: 'realestate',
    title: 'Real Estate Risk Analyzer',
    subtitle: '不動産リスク分析AI',
    description: '政府オープンデータ × 機械学習で不動産の液状化・洪水リスクと適正価格を可視化。',
    tags: ['Python', 'ML', 'Gov API', 'MCP Server'],
    accent: '#fbbf24',
  },
  {
    id: 'agent-platform',
    title: 'AI Agent Runtime',
    subtitle: '自律実行AIエージェント基盤',
    description: 'Rust × axum × WASMで構築した自律AIエージェント実行基盤。マルチクレート構成で拡張性と安全性を両立。',
    tags: ['Rust', 'axum', 'WASM', 'PostgreSQL'],
    accent: '#f97316',
  },
];
---

<section id="projects" class="relative py-32 md:py-40">
  <div class="max-w-5xl mx-auto px-6 md:px-12">
    <!-- Section number -->
    <div class="cin-reveal flex items-center gap-4 mb-10 md:mb-14">
      <span class="text-[10px] tracking-[0.3em] text-white/20 font-mono">03</span>
      <div class="w-8 h-px bg-white/10"></div>
      <span class="text-[10px] tracking-[0.2em] text-white/20 uppercase">Projects</span>
    </div>

    <!-- Title -->
    <div class="cin-reveal mb-16 md:mb-24">
      <h2 class="mask-reveal text-[6vw] md:text-[3.5vw] lg:text-[2.8vw] leading-[1.4] tracking-[0.01em] font-light">
        つくってきた<span class="font-serif italic">もの</span>たち
      </h2>
    </div>

    <!-- Project list -->
    <div class="space-y-0">
      {projects.map((project, idx) => (
        <article class="project-item group" data-cursor-hover data-mouse-target={project.title} data-accent={project.accent}>
          <div class="line-h w-full"></div>
          <div class="py-8 md:py-12 cin-reveal relative">
            <!-- Hover accent glow (background) -->
            <div
              class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-700 pointer-events-none"
              style={`background: linear-gradient(90deg, ${project.accent}05 0%, transparent 60%);`}
            ></div>

            <div class="relative flex flex-col md:flex-row md:items-start md:justify-between gap-4 md:gap-12">
              <!-- Left: number + title -->
              <div class="flex-1">
                <div class="flex items-center gap-3">
                  <span class="project-num font-heading text-3xl md:text-4xl font-extralight tabular-nums transition-colors duration-500" style={`color: rgba(255,255,255,0.08);`} data-hover-color={project.accent}>
                    {String(idx + 1).padStart(2, '0')}
                  </span>
                  <div class="w-4 h-px bg-white/10 group-hover:w-8 transition-all duration-500"></div>
                </div>
                <h3 class="font-heading text-xl md:text-2xl lg:text-3xl font-medium mt-3 leading-tight group-hover:text-white transition-colors duration-500">
                  {project.title}
                </h3>
                <p class="text-xs text-white/25 mt-1 tracking-wide group-hover:text-white/40 transition-colors duration-500">{project.subtitle}</p>
              </div>

              <!-- Right: description + tags -->
              <div class="md:max-w-sm md:text-right">
                <p class="text-sm text-white/30 leading-relaxed font-light group-hover:text-white/50 transition-colors duration-500">
                  {project.description}
                </p>
                <div class="flex flex-wrap md:justify-end gap-2 mt-4">
                  {project.tags.map(tag => (
                    <span
                      class="text-[10px] tracking-[0.1em] text-white/15 uppercase px-2 py-0.5 border border-white/[0.04] rounded-sm group-hover:border-white/[0.08] group-hover:text-white/30 transition-all duration-500"
                    >
                      {tag}
                    </span>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </article>
      ))}
      <div class="line-h w-full"></div>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('.project-item').forEach(item => {
    const num = item.querySelector('.project-num') as HTMLElement;
    const accent = (item as HTMLElement).dataset.accent;
    if (!num || !accent) return;

    item.addEventListener('mouseenter', () => {
      num.style.color = accent + '60';
    });
    item.addEventListener('mouseleave', () => {
      num.style.color = 'rgba(255,255,255,0.08)';
    });
  });
</script>
