const totalSkills = skillCategories.reduce((sum, cat) => sum + cat.items.length, 0);
---

<section id="skills" class="relative py-32 md:py-40 overflow-hidden">
  <div class="relative z-10 w-full max-w-7xl mx-auto px-6 md:px-12">
    <!-- Section number -->
    <div class="cin-reveal flex items-center gap-4 mb-10 md:mb-14">
      <span class="text-[10px] tracking-[0.3em] text-white/20 font-mono">02</span>
      <div class="w-8 h-px bg-white/10"></div>
      <span class="text-[10px] tracking-[0.2em] text-white/20 uppercase">Skills</span>
    </div>

    <!-- Title + lead -->
    <div class="cin-reveal mb-6 md:mb-8">
      <h2 class="mask-reveal text-[6vw] md:text-[3.5vw] lg:text-[2.8vw] leading-[1.4] tracking-[0.01em] font-light">
        技術を横断し、<span class="font-serif italic">統合</span>する
      </h2>
    </div>
    <div class="cin-reveal cin-delay-1 mb-14 md:mb-20 flex flex-col md:flex-row md:items-end md:justify-between gap-4">
      <p class="mask-reveal text-sm text-white/30 font-light leading-relaxed max-w-lg">
        フロントエンドからインフラ、AI、ブロックチェーンまで——<br class="hidden md:inline" />
        8領域・{totalSkills}+の技術スタックを横断的に扱い、プロダクトを丸ごと設計・構築します。
      </p>
      <div class="flex gap-8">
        <div class="group">
          <p class="font-heading text-2xl font-light transition-colors duration-500 group-hover:text-[#00f0ff]/60">{skillCategories.length}</p>
          <p class="text-[10px] tracking-[0.15em] text-white/20 uppercase mt-0.5">Domains</p>
        </div>
        <div class="group">
          <p class="font-heading text-2xl font-light transition-colors duration-500 group-hover:text-[#8b5cf6]/60">{totalSkills}+</p>
          <p class="text-[10px] tracking-[0.15em] text-white/20 uppercase mt-0.5">Technologies</p>
        </div>
      </div>
    </div>

    <!-- Skills grid with accent colors -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 md:gap-5" data-stagger-parent>
      {skillCategories.map((cat) => (
        <div class="skill-card" data-stagger-child data-accent={cat.accent}>
          <div class="skill-card-inner">
            <!-- Category header with accent bar -->
            <div class="mb-4 pb-3 border-b border-white/[0.06]">
              <div class="flex items-center gap-2.5 mb-2">
                <div class="w-1.5 h-1.5 rounded-full flex-shrink-0" style={`background: ${cat.accent};`}></div>
                <h3 class="text-xs tracking-[0.15em] uppercase font-medium text-white/60">
                  {cat.title}
                </h3>
              </div>
              <p class="text-[11px] text-white/20 font-light leading-relaxed pl-4">
                {cat.description}
              </p>
            </div>
            <ul class="space-y-1">
              {cat.items.map(item => (
                <li>
                  <a
                    href={item.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    data-mouse-target={item.name}
                    class="skill-link flex items-center gap-2 py-1 text-[13px] text-white/30 hover:text-white/90 transition-all duration-400 font-light group/link"
                  >
                    {item.icon && (
                      <span class={`${item.icon} text-[13px] flex-shrink-0 opacity-20 group-hover/link:opacity-60 transition-opacity duration-400`}></span>
                    )}
                    {!item.icon && (
                      <span class="w-[13px] h-[13px] flex-shrink-0 flex items-center justify-center opacity-20 group-hover/link:opacity-60 transition-opacity duration-400">
                        <span class="w-1 h-1 rounded-full bg-current"></span>
                      </span>
                    )}
                    <span class="relative">
                      {item.name}
                      <span class="absolute left-0 bottom-0 w-0 h-px group-hover/link:w-full transition-all duration-400" style={`background: ${cat.accent}40;`}></span>
                    </span>
                    <svg width="7" height="7" viewBox="0 0 10 10" fill="none" class="ml-auto opacity-0 group-hover/link:opacity-30 transition-all duration-400 flex-shrink-0 stroke-current translate-x-[-4px] group-hover/link:translate-x-0">
                      <path d="M1 1H9M9 1V9M9 1L1 9" stroke-linecap="round" stroke-linejoin="round" stroke-width="1"/>
                    </svg>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .skill-card {
    position: relative;
    padding: 1px;
    border-radius: 8px;
    background: transparent;
    transition: background 0.6s ease;
  }

  .skill-card:hover {
    background: linear-gradient(
      135deg,
      rgba(255,255,255,0.06) 0%,
      rgba(255,255,255,0.02) 50%,
      rgba(255,255,255,0.04) 100%
    );
  }

  .skill-card-inner {
    padding: 16px;
    border-radius: 7px;
    background: rgba(0,0,0,0.3);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    height: 100%;
    transition: background 0.6s ease;
  }

  .skill-card:hover .skill-card-inner {
    background: rgba(0,0,0,0.5);
  }
</style>
