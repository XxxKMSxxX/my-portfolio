  {
    title: 'Languages',
    accent: '#00f0ff',
    description: 'Webアプリ・高頻度取引Bot・データ分析、用途で言語を使い分ける',
    items: [
      { name: 'TypeScript', url: 'https://www.typescriptlang.org/', icon: 'i-simple-icons-typescript' },
      { name: 'Rust', url: 'https://www.rust-lang.org/', icon: 'i-simple-icons-rust' },
      { name: 'Python', url: 'https://www.python.org/', icon: 'i-simple-icons-python' },
      { name: 'Go', url: 'https://go.dev/', icon: 'i-simple-icons-go' },
      { name: 'SQL', url: 'https://ja.wikipedia.org/wiki/SQL' },
      { name: 'GLSL', url: 'https://www.khronos.org/opengl/wiki/OpenGL_Shading_Language', icon: 'i-simple-icons-opengl' },
