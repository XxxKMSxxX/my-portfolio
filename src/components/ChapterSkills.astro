      { name: 'dbt', url: 'https://www.getdbt.com/', icon: 'i-simple-icons-dbt' },
      { name: 'Apache Airflow', url: 'https://airflow.apache.org/', icon: 'i-simple-icons-apacheairflow' },
      { name: 'Great Expectations', url: 'https://greatexpectations.io/' },
      { name: 'Medallion Arch.', url: 'https://www.databricks.com/glossary/medallion-architecture', icon: 'i-simple-icons-databricks' },
