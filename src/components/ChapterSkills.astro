  },
  {
    title: 'Frontend',
    accent: '#8b5cf6',
    description: 'PWA・ダッシュボード・LPをApp Router + Server Actionsで構築',
    items: [
      { name: 'React', url: 'https://react.dev/', icon: 'i-simple-icons-react' },
      { name: 'Next.js', url: 'https://nextjs.org/', icon: 'i-simple-icons-nextdotjs' },
      { name: 'Astro', url: 'https://astro.build/', icon: 'i-simple-icons-astro' },
      { name: 'Vue.js', url: 'https://vuejs.org/', icon: 'i-simple-icons-vuedotjs' },
      { name: 'Tailwind CSS', url: 'https://tailwindcss.com/', icon: 'i-simple-icons-tailwindcss' },
      { name: 'Three.js', url: 'https://threejs.org/', icon: 'i-simple-icons-threedotjs' },
      { name: 'GSAP', url: 'https://gsap.com/', icon: 'i-simple-icons-greensock' },
      { name: 'Framer Motion', url: 'https://www.framer.com/motion/', icon: 'i-simple-icons-framer' },
    ],
  },
  {
    title: 'Backend',
    accent: '#f472b6',
    description: 'REST API・gRPC・WebSocketを要件に応じて設計・実装',
    items: [
      { name: 'Node.js', url: 'https://nodejs.org/', icon: 'i-simple-icons-nodedotjs' },
      { name: 'Hono', url: 'https://hono.dev/', icon: 'i-simple-icons-hono' },
      { name: 'FastAPI', url: 'https://fastapi.tiangolo.com/', icon: 'i-simple-icons-fastapi' },
      { name: 'axum', url: 'https://github.com/tokio-rs/axum' },
      { name: 'GraphQL', url: 'https://graphql.org/', icon: 'i-simple-icons-graphql' },
      { name: 'tRPC', url: 'https://trpc.io/' },
      { name: 'gRPC', url: 'https://grpc.io/' },
      { name: 'WebSocket', url: 'https://developer.mozilla.org/docs/Web/API/WebSockets_API' },
    ],
  },
  {
    title: 'AI / ML',
    accent: '#34d399',
    description: 'LLM連携・画像認識・時系列予測・グラフNNまで幅広く実装・運用',
    items: [
      { name: 'Claude API', url: 'https://docs.anthropic.com/', icon: 'i-simple-icons-anthropic' },
      { name: 'PyTorch', url: 'https://pytorch.org/', icon: 'i-simple-icons-pytorch' },
      { name: 'XGBoost', url: 'https://xgboost.readthedocs.io/' },
      { name: 'scikit-learn', url: 'https://scikit-learn.org/', icon: 'i-simple-icons-scikitlearn' },
      { name: 'MLflow', url: 'https://mlflow.org/', icon: 'i-simple-icons-mlflow' },
      { name: 'Qdrant', url: 'https://qdrant.tech/' },
      { name: 'MCP Server', url: 'https://modelcontextprotocol.io/', icon: 'i-simple-icons-anthropic' },
      { name: 'Vercel AI SDK', url: 'https://sdk.vercel.ai/', icon: 'i-simple-icons-vercel' },
    ],
  },
  {
    title: 'Database',
    accent: '#fbbf24',
    description: 'エッジDB・RDB・時系列DB・ベクトルDBを要件で選定',
    items: [
      { name: 'PostgreSQL', url: 'https://www.postgresql.org/', icon: 'i-simple-icons-postgresql' },
      { name: 'Turso', url: 'https://turso.tech/', icon: 'i-simple-icons-turso' },
      { name: 'DuckDB', url: 'https://duckdb.org/', icon: 'i-simple-icons-duckdb' },
