  },
  {
    title: 'Blockchain',
    accent: '#a78bfa',
    description: 'DEXアービトラージ・マーケットメイキングBotを設計・運用',
    items: [
      { name: 'Solana', url: 'https://solana.com/', icon: 'i-simple-icons-solana' },
      { name: 'Anchor', url: 'https://www.anchor-lang.com/' },
      { name: 'Flash Loan', url: 'https://docs.aave.com/developers/guides/flash-loans' },
      { name: 'Jito (MEV)', url: 'https://www.jito.network/' },
      { name: 'Yellowstone gRPC', url: 'https://github.com/rpcpool/yellowstone-grpc' },
    ],
  },
