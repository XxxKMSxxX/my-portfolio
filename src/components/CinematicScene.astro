---
---

<!-- Animated background with depth -->
<div class="geo-bg fixed inset-0 z-0 pointer-events-none overflow-hidden" aria-hidden="true">
  <!-- Dot grid pattern -->
  <svg class="absolute inset-0 w-full h-full opacity-[0.03]">
    <defs>
      <pattern id="dot-grid" x="0" y="0" width="40" height="40" patternUnits="userSpaceOnUse">
        <circle cx="1" cy="1" r="0.5" fill="white" />
      </pattern>
    </defs>
    <rect width="100%" height="100%" fill="url(#dot-grid)" />
  </svg>

  <!-- Animated gradient orbs (slow drift) -->
  <div class="orb orb-1"></div>
  <div class="orb orb-2"></div>
  <div class="orb orb-3"></div>

  <!-- CSS floating particles -->
  <div class="particles" aria-hidden="true">
    <div class="particle" style="--x: 15%; --y: 20%; --d: 8s; --delay: 0s; --size: 2px;"></div>
    <div class="particle" style="--x: 75%; --y: 60%; --d: 12s; --delay: 2s; --size: 1.5px;"></div>
    <div class="particle" style="--x: 40%; --y: 80%; --d: 10s; --delay: 4s; --size: 1px;"></div>
    <div class="particle" style="--x: 85%; --y: 30%; --d: 14s; --delay: 1s; --size: 2.5px;"></div>
    <div class="particle" style="--x: 25%; --y: 50%; --d: 9s; --delay: 3s; --size: 1px;"></div>
    <div class="particle" style="--x: 60%; --y: 15%; --d: 11s; --delay: 5s; --size: 1.5px;"></div>
    <div class="particle" style="--x: 50%; --y: 70%; --d: 13s; --delay: 2.5s; --size: 2px;"></div>
    <div class="particle" style="--x: 90%; --y: 85%; --d: 10s; --delay: 6s; --size: 1px;"></div>
  </div>
</div>

<!-- Structural vertical lines -->
<div class="fixed inset-0 z-[1] pointer-events-none" aria-hidden="true">
  <div class="absolute top-0 bottom-0 left-[7%] w-px bg-white/[0.03]"></div>
  <div class="absolute top-0 bottom-0 right-[7%] w-px bg-white/[0.03]"></div>
  <div class="absolute top-0 bottom-0 left-1/2 w-px bg-white/[0.015] hidden md:block"></div>
</div>

<style>
  .orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
    will-change: transform;
  }

  .orb-1 {
    top: -20vh;
    right: -10vw;
    width: 60vmax;
    height: 60vmax;
    opacity: 0.035;
    background: #4f46e5;
    animation: orbFloat1 25s ease-in-out infinite;
  }

  .orb-2 {
    bottom: -30vh;
    left: -15vw;
    width: 50vmax;
    height: 50vmax;
    opacity: 0.025;
    background: #06b6d4;
    animation: orbFloat2 30s ease-in-out infinite;
  }

  .orb-3 {
    top: 40%;
    left: 30%;
    width: 40vmax;
    height: 40vmax;
    opacity: 0.02;
    background: #8b5cf6;
    animation: orbFloat3 20s ease-in-out infinite;
  }

  @keyframes orbFloat1 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33%      { transform: translate(-5vw, 8vh) scale(1.1); }
    66%      { transform: translate(3vw, -5vh) scale(0.95); }
  }

  @keyframes orbFloat2 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33%      { transform: translate(8vw, -6vh) scale(0.9); }
    66%      { transform: translate(-4vw, 4vh) scale(1.08); }
  }

  @keyframes orbFloat3 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50%      { transform: translate(10vw, -10vh) scale(1.15); }
  }

  .particle {
    position: absolute;
    left: var(--x);
    top: var(--y);
    width: var(--size);
    height: var(--size);
    border-radius: 50%;
    background: white;
    opacity: 0;
    animation: particlePulse var(--d) ease-in-out var(--delay) infinite;
  }

  @keyframes particlePulse {
    0%, 100% { opacity: 0; transform: translateY(0) scale(1); }
    20%      { opacity: 0.15; }
    50%      { opacity: 0.3; transform: translateY(-30px) scale(1.5); }
    80%      { opacity: 0.1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .orb { animation: none; }
    .particle { animation: none; }
  }
</style>
