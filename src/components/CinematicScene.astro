---
---

<canvas id="cinematic-canvas" class="fixed inset-0 w-full h-full z-0"></canvas>

<script>
  import * as THREE from 'three';
  import { EffectComposer } from 'three/examples/jsm/postprocessing/EffectComposer.js';
  import { RenderPass } from 'three/examples/jsm/postprocessing/RenderPass.js';
  import { UnrealBloomPass } from 'three/examples/jsm/postprocessing/UnrealBloomPass.js';
  import { ShaderPass } from 'three/examples/jsm/postprocessing/ShaderPass.js';

  // ---- Custom post-processing shader: Chromatic Aberration + Vignette ----
  const CinematicShader = {
    uniforms: {
      tDiffuse: { value: null },
      uTime: { value: 0 },
      uChroma: { value: 0.002 },
      uVignette: { value: 0.85 },
      uScrollVelocity: { value: 0 },
    },
    vertexShader: /* glsl */ `
      varying vec2 vUv;
      void main() {
        vUv = uv;
        gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
      }
    `,
    fragmentShader: /* glsl */ `
      uniform sampler2D tDiffuse;
      uniform float uTime;
      uniform float uChroma;
      uniform float uVignette;
      uniform float uScrollVelocity;
      varying vec2 vUv;

      void main() {
        vec2 uv = vUv;

        // Chromatic aberration (increases with scroll velocity)
        float aberration = uChroma + abs(uScrollVelocity) * 0.008;
        vec2 dir = uv - 0.5;
        float d = length(dir);
        float offset = aberration * d;

        vec4 cr = texture2D(tDiffuse, uv + dir * offset);
        vec4 cg = texture2D(tDiffuse, uv);
        vec4 cb = texture2D(tDiffuse, uv - dir * offset);
        vec4 color = vec4(cr.r, cg.g, cb.b, 1.0);

        // Vignette
        float vignette = 1.0 - smoothstep(0.3, 1.2, d * 1.8);
        color.rgb *= mix(1.0, vignette, uVignette);

        // Subtle color grading (slight blue in shadows, warm highlights)
        color.rgb = pow(color.rgb, vec3(0.95, 1.0, 1.05));

        gl_FragColor = color;
      }
    `,
  };

  function initCinematicScene() {
    const canvas = document.getElementById('cinematic-canvas') as HTMLCanvasElement;
    if (!canvas) return;

    const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.setSize(window.innerWidth, window.innerHeight);
    renderer.toneMapping = THREE.ACESFilmicToneMapping;
    renderer.toneMappingExposure = 0.8;

    const scene = new THREE.Scene();
    scene.fog = new THREE.FogExp2(0x020202, 0.012);

    const camera = new THREE.PerspectiveCamera(60, window.innerWidth / window.innerHeight, 0.1, 1000);
    camera.position.set(0, 0, 50);

    // ---- Post-processing ----
    const composer = new EffectComposer(renderer);
    composer.addPass(new RenderPass(scene, camera));

    const bloomPass = new UnrealBloomPass(
      new THREE.Vector2(window.innerWidth, window.innerHeight),
      0.6,   // strength
      0.4,   // radius
      0.15,  // threshold
    );
    composer.addPass(bloomPass);

    const cinematicPass = new ShaderPass(CinematicShader);
    composer.addPass(cinematicPass);

    // ---- Particles ----
    const particleCount = window.innerWidth < 768 ? 800 : 2000;
    const pGeo = new THREE.BufferGeometry();
    const pPos = new Float32Array(particleCount * 3);
    const pColors = new Float32Array(particleCount * 3);
    const pSizes = new Float32Array(particleCount);
    const pOriginal = new Float32Array(particleCount * 3); // original positions

    const cyan = new THREE.Color('#00f0ff');
    const purple = new THREE.Color('#8b5cf6');
    const pink = new THREE.Color('#f472b6');
    const white = new THREE.Color('#ffffff');
    const palette = [cyan, purple, pink, white, cyan, purple];

    for (let i = 0; i < particleCount; i++) {
      const theta = Math.random() * Math.PI * 2;
      const phi = Math.acos(2 * Math.random() - 1);
      const r = 20 + Math.random() * 50;
      const x = r * Math.sin(phi) * Math.cos(theta);
      const y = r * Math.sin(phi) * Math.sin(theta);
      const z = r * Math.cos(phi);

      pPos[i * 3] = x;
      pPos[i * 3 + 1] = y;
      pPos[i * 3 + 2] = z;
      pOriginal[i * 3] = x;
      pOriginal[i * 3 + 1] = y;
      pOriginal[i * 3 + 2] = z;

      const color = palette[Math.floor(Math.random() * palette.length)];
      pColors[i * 3] = color.r;
      pColors[i * 3 + 1] = color.g;
      pColors[i * 3 + 2] = color.b;

      pSizes[i] = Math.random() * 2 + 0.5;
    }

    pGeo.setAttribute('position', new THREE.BufferAttribute(pPos, 3));
    pGeo.setAttribute('color', new THREE.BufferAttribute(pColors, 3));

    const pMat = new THREE.PointsMaterial({
      size: 0.06,
      vertexColors: true,
      transparent: true,
      opacity: 0.7,
      blending: THREE.AdditiveBlending,
      depthWrite: false,
    });

    const particles = new THREE.Points(pGeo, pMat);
    scene.add(particles);

    // ---- Wireframe geometries ----
    interface FloatingGeo {
      wireframe: THREE.LineSegments;
      solid: THREE.Mesh;
      basePos: THREE.Vector3;
      rotSpeed: THREE.Vector3;
      floatSpeed: number;
      floatAmp: number;
    }

    const geometries: FloatingGeo[] = [];

    function addGeo(
      geo: THREE.BufferGeometry,
      color: string,
      pos: [number, number, number],
      scale: number,
    ): FloatingGeo {
      const edges = new THREE.EdgesGeometry(geo);
      const wireMat = new THREE.LineBasicMaterial({ color, transparent: true, opacity: 0.12 });
      const wireframe = new THREE.LineSegments(edges, wireMat);
      wireframe.position.set(...pos);
      wireframe.scale.setScalar(scale);
      scene.add(wireframe);

      const solidMat = new THREE.MeshBasicMaterial({ color, transparent: true, opacity: 0.02, side: THREE.DoubleSide });
      const solid = new THREE.Mesh(geo, solidMat);
      solid.position.set(...pos);
      solid.scale.setScalar(scale);
      scene.add(solid);

      const entry: FloatingGeo = {
        wireframe,
        solid,
        basePos: new THREE.Vector3(...pos),
        rotSpeed: new THREE.Vector3(
          (Math.random() - 0.5) * 0.4,
          (Math.random() - 0.5) * 0.4,
          (Math.random() - 0.5) * 0.2,
        ),
        floatSpeed: 0.3 + Math.random() * 0.5,
        floatAmp: 1 + Math.random() * 2,
      };
      geometries.push(entry);
      return entry;
    }

    addGeo(new THREE.IcosahedronGeometry(1, 1), '#00f0ff', [-18, 10, -15], 4);
    addGeo(new THREE.TorusKnotGeometry(1, 0.3, 64, 16), '#8b5cf6', [16, -6, -20], 3);
    addGeo(new THREE.OctahedronGeometry(1, 0), '#f472b6', [-12, -12, -25], 3.5);
    addGeo(new THREE.DodecahedronGeometry(1, 0), '#00f0ff', [20, 12, -18], 2.5);
    addGeo(new THREE.TorusGeometry(1, 0.3, 8, 24), '#8b5cf6', [-5, 18, -30], 4);
    addGeo(new THREE.TetrahedronGeometry(1, 0), '#f472b6', [25, -15, -22], 3);
    addGeo(new THREE.IcosahedronGeometry(1, 0), '#00f0ff', [0, -20, -35], 5);

    // ---- Connection lines ----
    const lineGeo = new THREE.BufferGeometry();
    const linePositions = new Float32Array(300 * 6);
    lineGeo.setAttribute('position', new THREE.BufferAttribute(linePositions, 3));
    const lineMat = new THREE.LineBasicMaterial({
      color: '#00f0ff',
      transparent: true,
      opacity: 0.03,
      blending: THREE.AdditiveBlending,
    });
    const connectionLines = new THREE.LineSegments(lineGeo, lineMat);
    scene.add(connectionLines);

    // ---- Scroll state ----
    let scrollProgress = 0;
    let scrollVelocity = 0;
    let prevScroll = 0;
    let mouseX = 0, mouseY = 0;

    window.addEventListener('scroll', () => {
      const scrollTop = window.scrollY;
      const docHeight = document.documentElement.scrollHeight - window.innerHeight;
      scrollProgress = docHeight > 0 ? scrollTop / docHeight : 0;
      scrollVelocity = (scrollTop - prevScroll) / window.innerHeight;
      prevScroll = scrollTop;
    });

    document.addEventListener('mousemove', (e) => {
      mouseX = (e.clientX / window.innerWidth - 0.5) * 2;
      mouseY = -(e.clientY / window.innerHeight - 0.5) * 2;
    });

    // ---- Camera keyframes ----
    interface CameraKeyframe {
      t: number;
      pos: [number, number, number];
      lookAt: [number, number, number];
    }

    const cameraPath: CameraKeyframe[] = [
      { t: 0.0,  pos: [0, 0, 50],     lookAt: [0, 0, 0] },
      { t: 0.15, pos: [0, 2, 40],     lookAt: [0, 0, -5] },
      { t: 0.3,  pos: [-8, 4, 30],    lookAt: [-3, 0, -10] },
      { t: 0.5,  pos: [6, -2, 25],    lookAt: [3, 0, -15] },
      { t: 0.7,  pos: [-4, 6, 20],    lookAt: [0, 2, -20] },
      { t: 0.85, pos: [2, 0, 15],     lookAt: [0, 0, -10] },
      { t: 1.0,  pos: [0, 0, 12],     lookAt: [0, 0, -5] },
    ];

    function lerpCameraPath(t: number) {
      const clamped = Math.max(0, Math.min(1, t));
      let i = 0;
      for (let k = 0; k < cameraPath.length - 1; k++) {
        if (clamped >= cameraPath[k].t && clamped <= cameraPath[k + 1].t) {
          i = k;
          break;
        }
      }
      const a = cameraPath[i];
      const b = cameraPath[i + 1];
      const local = (clamped - a.t) / (b.t - a.t);
      // Smooth step for cinematic feel
      const smooth = local * local * (3 - 2 * local);
      return {
        pos: a.pos.map((v, j) => v + (b.pos[j] - v) * smooth) as [number, number, number],
        lookAt: a.lookAt.map((v, j) => v + (b.lookAt[j] - v) * smooth) as [number, number, number],
      };
    }

    // ---- Animation loop ----
    let time = 0;
    const targetCamPos = new THREE.Vector3();
    const targetLookAt = new THREE.Vector3();
    const currentCamPos = new THREE.Vector3(0, 0, 50);
    const currentLookAt = new THREE.Vector3(0, 0, 0);

    function updateConnections() {
      const posArr = pGeo.attributes.position.array as Float32Array;
      let idx = 0;
      const max = 300;
      const thresh = 10;

      for (let i = 0; i < particleCount && idx < max; i += 12) {
        for (let j = i + 12; j < particleCount && idx < max; j += 12) {
          const dx = posArr[i * 3] - posArr[j * 3];
          const dy = posArr[i * 3 + 1] - posArr[j * 3 + 1];
          const dz = posArr[i * 3 + 2] - posArr[j * 3 + 2];
          if (dx * dx + dy * dy + dz * dz < thresh * thresh) {
            linePositions[idx * 6] = posArr[i * 3];
            linePositions[idx * 6 + 1] = posArr[i * 3 + 1];
            linePositions[idx * 6 + 2] = posArr[i * 3 + 2];
            linePositions[idx * 6 + 3] = posArr[j * 3];
            linePositions[idx * 6 + 4] = posArr[j * 3 + 1];
            linePositions[idx * 6 + 5] = posArr[j * 3 + 2];
            idx++;
          }
        }
      }
      connectionLines.geometry.setDrawRange(0, idx * 2);
      connectionLines.geometry.attributes.position.needsUpdate = true;
    }

    function animate() {
      requestAnimationFrame(animate);
      time += 0.016;

      // Camera from scroll
      const cam = lerpCameraPath(scrollProgress);
      targetCamPos.set(...cam.pos);
      targetLookAt.set(...cam.lookAt);

      // Add mouse parallax
      targetCamPos.x += mouseX * 2;
      targetCamPos.y += mouseY * 1.5;

      // Smooth interpolation
      currentCamPos.lerp(targetCamPos, 0.04);
      currentLookAt.lerp(targetLookAt, 0.04);
      camera.position.copy(currentCamPos);
      camera.lookAt(currentLookAt);

      // Particles rotation + scroll velocity effect
      particles.rotation.y = time * 0.02;
      particles.rotation.x = time * 0.008 + scrollProgress * 0.5;

      // Scroll velocity spreads particles
      const posArr = pGeo.attributes.position.array as Float32Array;
      const vel = Math.abs(scrollVelocity);
      for (let i = 0; i < particleCount; i++) {
        const ox = pOriginal[i * 3];
        const oy = pOriginal[i * 3 + 1];
        const oz = pOriginal[i * 3 + 2];
        const spread = 1 + vel * 3;
        posArr[i * 3] += (ox * spread - posArr[i * 3]) * 0.02;
        posArr[i * 3 + 1] += (oy * spread - posArr[i * 3 + 1]) * 0.02;
        posArr[i * 3 + 2] += (oz * spread - posArr[i * 3 + 2]) * 0.02;
      }
      pGeo.attributes.position.needsUpdate = true;

      // Geometries float + rotate
      geometries.forEach((g, i) => {
        g.wireframe.rotation.x += g.rotSpeed.x * 0.016;
        g.wireframe.rotation.y += g.rotSpeed.y * 0.016;
        g.wireframe.rotation.z += g.rotSpeed.z * 0.016;
        g.solid.rotation.copy(g.wireframe.rotation);

        const floatY = Math.sin(time * g.floatSpeed + i * 1.5) * g.floatAmp;
        g.wireframe.position.y = g.basePos.y + floatY;
        g.solid.position.y = g.wireframe.position.y;
      });

      // Scroll velocity to post-processing
      scrollVelocity *= 0.95; // decay
      cinematicPass.uniforms.uScrollVelocity.value += (scrollVelocity - cinematicPass.uniforms.uScrollVelocity.value) * 0.1;
      cinematicPass.uniforms.uTime.value = time;

      updateConnections();
      composer.render();
    }

    animate();

    window.addEventListener('resize', () => {
      camera.aspect = window.innerWidth / window.innerHeight;
      camera.updateProjectionMatrix();
      renderer.setSize(window.innerWidth, window.innerHeight);
      composer.setSize(window.innerWidth, window.innerHeight);
    });
  }

  initCinematicScene();
</script>
