---
---

<!-- Animated background with depth -->
<div class="geo-bg fixed inset-0 z-0 pointer-events-none overflow-hidden" aria-hidden="true">
  <!-- Fine grid pattern -->
  <svg class="absolute inset-0 w-full h-full opacity-[0.04]">
    <defs>
      <pattern id="fine-grid" x="0" y="0" width="60" height="60" patternUnits="userSpaceOnUse">
        <path d="M60 0H0V60" fill="none" stroke="white" stroke-width="0.3" />
      </pattern>
    </defs>
    <rect width="100%" height="100%" fill="url(#fine-grid)" />
  </svg>

  <!-- Radial gradient spotlight (top) -->
  <div class="spotlight spotlight-1"></div>
  <!-- Secondary spotlight (bottom-left) -->
  <div class="spotlight spotlight-2"></div>
  <!-- Accent spotlight (right) -->
  <div class="spotlight spotlight-3"></div>

  <!-- Noise texture overlay -->
  <div class="absolute inset-0 opacity-[0.015]" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 256 256%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22n%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.9%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23n)%22/%3E%3C/svg%3E'); background-size: 200px;"></div>

  <!-- CSS floating particles -->
  <div class="particles">
    <div class="particle" style="--x: 12%; --y: 18%; --d: 8s; --delay: 0s; --size: 2px; --color: #00f0ff;"></div>
    <div class="particle" style="--x: 78%; --y: 55%; --d: 12s; --delay: 2s; --size: 1.5px; --color: #8b5cf6;"></div>
    <div class="particle" style="--x: 35%; --y: 75%; --d: 10s; --delay: 4s; --size: 1px; --color: #34d399;"></div>
    <div class="particle" style="--x: 88%; --y: 25%; --d: 14s; --delay: 1s; --size: 2.5px; --color: #f472b6;"></div>
    <div class="particle" style="--x: 22%; --y: 45%; --d: 9s; --delay: 3s; --size: 1px; --color: #fbbf24;"></div>
    <div class="particle" style="--x: 62%; --y: 12%; --d: 11s; --delay: 5s; --size: 1.5px; --color: #00f0ff;"></div>
    <div class="particle" style="--x: 48%; --y: 65%; --d: 13s; --delay: 2.5s; --size: 2px; --color: #8b5cf6;"></div>
    <div class="particle" style="--x: 92%; --y: 80%; --d: 10s; --delay: 6s; --size: 1px; --color: #34d399;"></div>
    <div class="particle" style="--x: 8%; --y: 88%; --d: 15s; --delay: 7s; --size: 1.5px; --color: #f97316;"></div>
    <div class="particle" style="--x: 55%; --y: 35%; --d: 11s; --delay: 1.5s; --size: 2px; --color: #06b6d4;"></div>
  </div>
</div>

<!-- Structural vertical lines (stronger) -->
<div class="fixed inset-0 z-[1] pointer-events-none" aria-hidden="true">
  <div class="absolute top-0 bottom-0 left-[7%] w-px bg-white/[0.05]"></div>
  <div class="absolute top-0 bottom-0 right-[7%] w-px bg-white/[0.05]"></div>
  <div class="absolute top-0 bottom-0 left-1/2 w-px bg-white/[0.025] hidden md:block"></div>
</div>

<style>
  .spotlight {
    position: absolute;
    border-radius: 50%;
    will-change: transform;
  }

  .spotlight-1 {
    top: -30vh;
    right: -15vw;
    width: 70vmax;
    height: 70vmax;
    opacity: 0.06;
    background: radial-gradient(circle, #4f46e5 0%, transparent 70%);
    animation: spotFloat1 20s ease-in-out infinite;
  }

  .spotlight-2 {
    bottom: -25vh;
    left: -20vw;
    width: 60vmax;
    height: 60vmax;
    opacity: 0.04;
    background: radial-gradient(circle, #06b6d4 0%, transparent 70%);
    animation: spotFloat2 25s ease-in-out infinite;
  }

  .spotlight-3 {
    top: 30%;
    right: -10vw;
    width: 45vmax;
    height: 45vmax;
    opacity: 0.03;
    background: radial-gradient(circle, #8b5cf6 0%, transparent 70%);
    animation: spotFloat3 18s ease-in-out infinite;
  }

  @keyframes spotFloat1 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33%      { transform: translate(-4vw, 6vh) scale(1.08); }
    66%      { transform: translate(2vw, -4vh) scale(0.96); }
  }

  @keyframes spotFloat2 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33%      { transform: translate(6vw, -5vh) scale(0.92); }
    66%      { transform: translate(-3vw, 3vh) scale(1.06); }
  }

  @keyframes spotFloat3 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50%      { transform: translate(-8vw, 8vh) scale(1.12); }
  }

  .particle {
    position: absolute;
    left: var(--x);
    top: var(--y);
    width: var(--size);
    height: var(--size);
    border-radius: 50%;
    background: var(--color);
    opacity: 0;
    animation: particlePulse var(--d) ease-in-out var(--delay) infinite;
    box-shadow: 0 0 6px var(--color);
  }

  @keyframes particlePulse {
    0%, 100% { opacity: 0; transform: translateY(0) scale(1); }
    20%      { opacity: 0.2; }
    50%      { opacity: 0.5; transform: translateY(-20px) scale(1.5); }
    80%      { opacity: 0.15; }
  }

  @media (prefers-reduced-motion: reduce) {
    .spotlight { animation: none; }
    .particle { animation: none; }
  }
</style>
