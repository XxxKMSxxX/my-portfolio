---
const socials = [
  { label: 'GitHub', href: '#', icon: 'i-carbon-logo-github' },
  { label: 'Twitter', href: '#', icon: 'i-carbon-logo-x' },
  { label: 'LinkedIn', href: '#', icon: 'i-carbon-logo-linkedin' },
];
---

<section id="contact" class="relative py-32 px-6">
  <div class="max-w-4xl mx-auto text-center">
    <p class="reveal text-[#00f0ff] text-sm tracking-[0.3em] uppercase mb-4 font-heading">Contact</p>
    <h2 class="reveal reveal-delay-1 font-heading text-4xl md:text-6xl font-bold mb-6">
      Let's Create<br />
      <span class="bg-gradient-to-r from-[#00f0ff] via-[#8b5cf6] to-[#f472b6] bg-clip-text" style="color: transparent; -webkit-background-clip: text;">
        Something Amazing
      </span>
    </h2>
    <p class="reveal reveal-delay-2 text-white/50 text-lg max-w-xl mx-auto mb-10">
      新しいプロジェクトやコラボレーションのご相談、お気軽にお問い合わせください。
    </p>
    <div class="reveal reveal-delay-3">
      <a
        href="mailto:hello@example.com"
        class="inline-flex items-center gap-3 px-10 py-4 bg-gradient-to-r from-[#00f0ff] to-[#8b5cf6] text-[#050505] font-semibold rounded-full
               hover:shadow-[0_0_40px_rgba(0,240,255,0.3)] transition-all duration-500 text-sm tracking-wide uppercase"
      >
        Get in Touch
      </a>
    </div>

    <!-- Social links -->
    <div class="reveal reveal-delay-4 flex items-center justify-center gap-6 mt-12">
      {socials.map(social => (
        <a
          href={social.href}
          class="w-12 h-12 rounded-full border border-white/10 flex items-center justify-center
                 text-white/40 hover:text-[#00f0ff] hover:border-[#00f0ff]/30 transition-all duration-300"
          aria-label={social.label}
        >
          <span class={`${social.icon} text-xl`}></span>
        </a>
      ))}
    </div>
  </div>
</section>

<!-- Footer -->
<footer class="border-t border-white/5 py-8 px-6">
  <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4">
    <p class="text-white/30 text-sm">
      &copy; {new Date().getFullYear()} Portfolio. All rights reserved.
    </p>
    <p class="text-white/20 text-xs">
      Built with Astro + Three.js
    </p>
  </div>
</footer>
