---
---

<section id="epilogue" class="relative min-h-screen flex items-center justify-center py-40 px-6">
  <div class="max-w-4xl mx-auto text-center">
    <!-- Chapter card -->
    <div class="chapter-card mb-16">
      <span class="font-heading text-7xl md:text-9xl font-bold text-white/[0.03]">FIN</span>
    </div>

    <h2 class="cin-reveal font-heading text-4xl md:text-7xl font-bold mb-6 leading-tight">
      Let's Build<br />
      <span class="bg-gradient-to-r from-[#00f0ff] via-[#8b5cf6] to-[#f472b6] bg-clip-text" style="color: transparent; -webkit-background-clip: text;">
        The Future
      </span>
    </h2>

    <p class="cin-reveal cin-delay-1 text-white/35 text-lg max-w-lg mx-auto mb-12 leading-relaxed">
      新しいプロジェクト、コラボレーション、技術的な挑戦——<br />
      お気軽にお声がけください。
    </p>

    <div class="cin-reveal cin-delay-2 mb-16">
      <a
        href="mailto:info@ai-hikari.com"
        class="inline-flex items-center gap-3 px-10 py-4 rounded-full border border-[#00f0ff]/30 text-[#00f0ff]
               hover:bg-[#00f0ff]/10 hover:border-[#00f0ff]/50 hover:shadow-[0_0_40px_rgba(0,240,255,0.15)]
               transition-all duration-500 text-sm tracking-[0.2em] uppercase"
      >
        Get in Touch
      </a>
    </div>

    <!-- Social links -->
    <div class="cin-reveal cin-delay-3 flex items-center justify-center gap-8">
      <a
        href="https://github.com/XxxKMSxxX"
        target="_blank"
        rel="noopener noreferrer"
        class="group flex flex-col items-center gap-2"
      >
        <span class="i-carbon-logo-github text-xl text-white/25 group-hover:text-[#00f0ff] transition-colors duration-300"></span>
        <span class="text-[9px] tracking-[0.2em] uppercase text-white/15 group-hover:text-white/40 transition-colors duration-300">GitHub</span>
      </a>
      <a
        href="https://www.linkedin.com/in/%E4%BF%8A-%E6%9C%A8%E6%9D%91-104821375/"
        target="_blank"
        rel="noopener noreferrer"
        class="group flex flex-col items-center gap-2"
      >
        <span class="i-carbon-logo-linkedin text-xl text-white/25 group-hover:text-[#8b5cf6] transition-colors duration-300"></span>
        <span class="text-[9px] tracking-[0.2em] uppercase text-white/15 group-hover:text-white/40 transition-colors duration-300">LinkedIn</span>
      </a>
    </div>
  </div>
</section>

<!-- Footer -->
<footer class="border-t border-white/[0.03] py-8 px-6">
  <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4">
    <p class="text-white/15 text-xs tracking-wider">
      &copy; {new Date().getFullYear()} Kimura Shun. All rights reserved.
    </p>
    <p class="text-white/10 text-[10px] tracking-wider uppercase">
      Built with Astro + Three.js + GLSL
    </p>
  </div>
</footer>
