---
---

<section id="hero" class="relative w-full h-screen flex items-center justify-center overflow-hidden">
  <canvas id="hero-canvas" class="absolute inset-0 w-full h-full"></canvas>

  <!-- Gradient overlay -->
  <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-[#050505] pointer-events-none"></div>

  <div class="relative z-10 text-center px-6 max-w-4xl">
    <p class="text-[#00f0ff] text-sm md:text-base tracking-[0.3em] uppercase mb-4 font-heading opacity-0 animate-fade-in">
      Creative Developer
    </p>
    <h1 class="font-heading text-5xl md:text-7xl lg:text-8xl font-bold leading-tight mb-6 opacity-0 animate-fade-in-delay-1">
      <span class="block">Crafting Digital</span>
      <span class="block bg-gradient-to-r from-[#00f0ff] via-[#8b5cf6] to-[#f472b6] bg-clip-text" style="color: transparent; -webkit-background-clip: text;">
        Experiences
      </span>
    </h1>
    <p class="text-lg md:text-xl text-white/50 max-w-2xl mx-auto mb-10 opacity-0 animate-fade-in-delay-2">
      インタラクティブなWebアプリケーションと没入型デジタル体験を創造するエンジニア
    </p>
    <div class="flex items-center justify-center gap-4 opacity-0 animate-fade-in-delay-3">
      <a
        href="#projects"
        class="group relative px-8 py-3 bg-[#00f0ff]/10 border border-[#00f0ff]/30 text-[#00f0ff] rounded-full
               hover:bg-[#00f0ff]/20 hover:border-[#00f0ff]/60 transition-all duration-500 text-sm tracking-wide uppercase"
      >
        <span class="relative z-10">View Works</span>
      </a>
      <a
        href="#contact"
        class="px-8 py-3 text-white/60 hover:text-white transition-colors duration-300 text-sm tracking-wide uppercase"
      >
        Contact Me
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 opacity-0 animate-fade-in-delay-3">
    <span class="text-white/30 text-xs tracking-widest uppercase">Scroll</span>
    <div class="w-px h-8 bg-gradient-to-b from-white/30 to-transparent animate-scroll-line"></div>
  </div>
</section>

<style>
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes scrollLine {
    0% { transform: scaleY(0); transform-origin: top; }
    50% { transform: scaleY(1); transform-origin: top; }
    51% { transform-origin: bottom; }
    100% { transform: scaleY(0); transform-origin: bottom; }
  }

  .animate-fade-in { animation: fadeIn 1s cubic-bezier(0.16, 1, 0.3, 1) 0.3s forwards; }
  .animate-fade-in-delay-1 { animation: fadeIn 1s cubic-bezier(0.16, 1, 0.3, 1) 0.6s forwards; }
  .animate-fade-in-delay-2 { animation: fadeIn 1s cubic-bezier(0.16, 1, 0.3, 1) 0.9s forwards; }
  .animate-fade-in-delay-3 { animation: fadeIn 1s cubic-bezier(0.16, 1, 0.3, 1) 1.2s forwards; }
  .animate-scroll-line { animation: scrollLine 2s ease-in-out infinite; }
</style>

<script>
  import * as THREE from 'three';

  function initHeroScene() {
    const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement;
    if (!canvas) return;

    const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.setSize(window.innerWidth, window.innerHeight);

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(60, window.innerWidth / window.innerHeight, 0.1, 1000);
    camera.position.z = 30;

    // Particles
    const particleCount = 1500;
    const particleGeometry = new THREE.BufferGeometry();
    const positions = new Float32Array(particleCount * 3);
    const colors = new Float32Array(particleCount * 3);
    const sizes = new Float32Array(particleCount);

    const cyan = new THREE.Color('#00f0ff');
    const purple = new THREE.Color('#8b5cf6');
    const pink = new THREE.Color('#f472b6');
    const colorChoices = [cyan, purple, pink];

    for (let i = 0; i < particleCount; i++) {
      positions[i * 3] = (Math.random() - 0.5) * 80;
      positions[i * 3 + 1] = (Math.random() - 0.5) * 80;
      positions[i * 3 + 2] = (Math.random() - 0.5) * 80;

      const color = colorChoices[Math.floor(Math.random() * colorChoices.length)];
      colors[i * 3] = color.r;
      colors[i * 3 + 1] = color.g;
      colors[i * 3 + 2] = color.b;

      sizes[i] = Math.random() * 2 + 0.5;
    }

    particleGeometry.setAttribute('position', new THREE.BufferAttribute(positions, 3));
    particleGeometry.setAttribute('color', new THREE.BufferAttribute(colors, 3));
    particleGeometry.setAttribute('size', new THREE.BufferAttribute(sizes, 1));

    const particleMaterial = new THREE.PointsMaterial({
      size: 0.08,
      vertexColors: true,
      transparent: true,
      opacity: 0.8,
      blending: THREE.AdditiveBlending,
      depthWrite: false,
    });

    const particles = new THREE.Points(particleGeometry, particleMaterial);
    scene.add(particles);

    // Wireframe geometries
    const geometries: THREE.Mesh[] = [];

    const createWireframeMesh = (
      geometry: THREE.BufferGeometry,
      color: string,
      position: THREE.Vector3,
      scale: number,
    ) => {
      const edges = new THREE.EdgesGeometry(geometry);
      const material = new THREE.LineBasicMaterial({
        color,
        transparent: true,
        opacity: 0.15,
      });
      const wireframe = new THREE.LineSegments(edges, material);
      wireframe.position.copy(position);
      wireframe.scale.setScalar(scale);
      scene.add(wireframe);

      const solidMaterial = new THREE.MeshBasicMaterial({
        color,
        transparent: true,
        opacity: 0.03,
        side: THREE.DoubleSide,
      });
      const mesh = new THREE.Mesh(geometry, solidMaterial);
      mesh.position.copy(position);
      mesh.scale.setScalar(scale);
      scene.add(mesh);

      geometries.push(mesh);
      (wireframe as unknown as THREE.Mesh).userData.linkedMesh = mesh;
      geometries.push(wireframe as unknown as THREE.Mesh);

      return wireframe;
    };

    const icosa = createWireframeMesh(
      new THREE.IcosahedronGeometry(1, 1),
      '#00f0ff',
      new THREE.Vector3(-12, 5, -10),
      4,
    );

    const torus = createWireframeMesh(
      new THREE.TorusGeometry(1, 0.4, 8, 16),
      '#8b5cf6',
      new THREE.Vector3(14, -3, -8),
      3.5,
    );

    const octa = createWireframeMesh(
      new THREE.OctahedronGeometry(1, 0),
      '#f472b6',
      new THREE.Vector3(-8, -8, -15),
      3,
    );

    const dodeca = createWireframeMesh(
      new THREE.DodecahedronGeometry(1, 0),
      '#00f0ff',
      new THREE.Vector3(10, 8, -12),
      2.5,
    );

    // Connection lines
    const lineGeometry = new THREE.BufferGeometry();
    const linePositions = new Float32Array(200 * 6);
    lineGeometry.setAttribute('position', new THREE.BufferAttribute(linePositions, 3));
    const lineMaterial = new THREE.LineBasicMaterial({
      color: '#00f0ff',
      transparent: true,
      opacity: 0.04,
      blending: THREE.AdditiveBlending,
    });
    const connectionLines = new THREE.LineSegments(lineGeometry, lineMaterial);
    scene.add(connectionLines);

    // Mouse interaction
    const mouse = { x: 0, y: 0, targetX: 0, targetY: 0 };

    document.addEventListener('mousemove', (e) => {
      mouse.targetX = (e.clientX / window.innerWidth - 0.5) * 2;
      mouse.targetY = -(e.clientY / window.innerHeight - 0.5) * 2;
    });

    // Animation
    const clock = new THREE.Clock();

    function updateConnections() {
      const posArray = particleGeometry.attributes.position.array as Float32Array;
      let lineIndex = 0;
      const maxConnections = 200;
      const threshold = 12;

      for (let i = 0; i < particleCount && lineIndex < maxConnections; i += 10) {
        for (let j = i + 10; j < particleCount && lineIndex < maxConnections; j += 10) {
          const dx = posArray[i * 3] - posArray[j * 3];
          const dy = posArray[i * 3 + 1] - posArray[j * 3 + 1];
          const dz = posArray[i * 3 + 2] - posArray[j * 3 + 2];
          const dist = Math.sqrt(dx * dx + dy * dy + dz * dz);

          if (dist < threshold) {
            linePositions[lineIndex * 6] = posArray[i * 3];
            linePositions[lineIndex * 6 + 1] = posArray[i * 3 + 1];
            linePositions[lineIndex * 6 + 2] = posArray[i * 3 + 2];
            linePositions[lineIndex * 6 + 3] = posArray[j * 3];
            linePositions[lineIndex * 6 + 4] = posArray[j * 3 + 1];
            linePositions[lineIndex * 6 + 5] = posArray[j * 3 + 2];
            lineIndex++;
          }
        }
      }

      connectionLines.geometry.setDrawRange(0, lineIndex * 2);
      connectionLines.geometry.attributes.position.needsUpdate = true;
    }

    function animate() {
      requestAnimationFrame(animate);
      const elapsed = clock.getElapsedTime();

      // Smooth mouse follow
      mouse.x += (mouse.targetX - mouse.x) * 0.05;
      mouse.y += (mouse.targetY - mouse.y) * 0.05;

      // Camera movement
      camera.position.x = mouse.x * 3;
      camera.position.y = mouse.y * 2;
      camera.lookAt(0, 0, 0);

      // Rotate particles
      particles.rotation.y = elapsed * 0.03;
      particles.rotation.x = elapsed * 0.01;

      // Rotate geometries
      icosa.rotation.x = elapsed * 0.2;
      icosa.rotation.y = elapsed * 0.15;

      torus.rotation.x = elapsed * 0.15;
      torus.rotation.z = elapsed * 0.1;

      octa.rotation.y = elapsed * 0.25;
      octa.rotation.z = elapsed * 0.1;

      dodeca.rotation.x = elapsed * 0.1;
      dodeca.rotation.y = elapsed * 0.2;

      // Float geometries
      icosa.position.y = 5 + Math.sin(elapsed * 0.5) * 2;
      torus.position.y = -3 + Math.sin(elapsed * 0.4 + 1) * 1.5;
      octa.position.y = -8 + Math.sin(elapsed * 0.6 + 2) * 1.8;
      dodeca.position.y = 8 + Math.sin(elapsed * 0.3 + 3) * 2.5;

      // Sync linked meshes
      geometries.forEach(g => {
        if (g.userData.linkedMesh) {
          const linked = g.userData.linkedMesh as THREE.Mesh;
          linked.rotation.copy(g.rotation);
          linked.position.copy(g.position);
        }
      });

      updateConnections();
      renderer.render(scene, camera);
    }

    animate();

    window.addEventListener('resize', () => {
      camera.aspect = window.innerWidth / window.innerHeight;
      camera.updateProjectionMatrix();
      renderer.setSize(window.innerWidth, window.innerHeight);
    });
  }

  initHeroScene();
</script>
