---

<div id="loading-overlay" class="fixed inset-0 z-[9999] bg-black flex items-center justify-center">
  <div class="text-center">
    <p id="loading-name" class="font-heading text-sm tracking-[0.3em] uppercase text-white/0">Kimura Shun</p>
    <div class="mt-6 w-24 h-px bg-white/5 mx-auto overflow-hidden">
      <div id="loading-bar" class="h-full bg-white/40" style="width: 0%; transition: width 0.1s linear;"></div>
    </div>
  </div>
</div>

<script>
  const overlay = document.getElementById('loading-overlay');
  const name = document.getElementById('loading-name');
  const bar = document.getElementById('loading-bar');
  let progress = 0;

  function tick() {
    if (progress >= 100) {
      if (bar) bar.style.width = '100%';
      setTimeout(hide, 300);
      return;
    }
    progress += Math.floor(Math.random() * 12) + 3;
    if (progress > 100) progress = 100;
    if (bar) bar.style.width = `${progress}%`;
    // Fade in name
    if (name && progress > 30) {
      name.style.transition = 'color 0.6s';
      name.style.color = 'rgba(255,255,255,0.6)';
    }
    setTimeout(tick, 30 + Math.random() * 50);
  }

  function hide() {
    if (!overlay) return;
    overlay.style.transition = 'opacity 0.6s cubic-bezier(.46,0,.17,1)';
    overlay.style.opacity = '0';
    setTimeout(() => {
      overlay.style.pointerEvents = 'none';
      document.body.classList.add('loaded');
    }, 600);
  }

  setTimeout(tick, 150);
</script>
