---
const items = [
  'TypeScript', 'Rust', 'Python', 'React', 'Next.js', 'Astro', 'Vue.js',
  'Three.js', 'FastAPI', 'axum', 'GraphQL', 'Solana', 'AWS', 'Terraform',
  'Kubernetes', 'Docker', 'PostgreSQL', 'LangChain', 'GSAP', 'WebGL',
];

const separator = '\u00A0\u00A0\u00B7\u00A0\u00A0';
---

<div class="marquee-wrap relative py-20 md:py-28 overflow-hidden select-none" aria-hidden="true">
  <!-- Fade edges (stronger) -->
  <div class="absolute left-0 top-0 bottom-0 w-24 md:w-32 bg-gradient-to-r from-black to-transparent z-10 pointer-events-none"></div>
  <div class="absolute right-0 top-0 bottom-0 w-24 md:w-32 bg-gradient-to-l from-black to-transparent z-10 pointer-events-none"></div>

  <!-- Track 1 (large, subtle) -->
  <div class="mb-3 overflow-hidden">
    <div class="marquee-track" style="--marquee-duration: 50s;">
      {[...Array(2)].map(() => (
        <span class="flex items-center gap-0 whitespace-nowrap">
          {items.map(item => (
            <span class="font-heading text-3xl md:text-5xl lg:text-6xl font-extralight text-white/[0.04] tracking-tight">
              {item}{separator}
            </span>
          ))}
        </span>
      ))}
    </div>
  </div>

  <!-- Track 2 (reverse, serif, offset) -->
  <div class="overflow-hidden">
    <div class="marquee-track" style="--marquee-duration: 65s; animation-direction: reverse;">
      {[...Array(2)].map(() => (
        <span class="flex items-center gap-0 whitespace-nowrap">
          {items.map(item => (
            <span class="font-serif italic text-3xl md:text-5xl lg:text-6xl font-extralight text-white/[0.025] tracking-tight">
              {item}{separator}
            </span>
          ))}
        </span>
      ))}
    </div>
  </div>
</div>
