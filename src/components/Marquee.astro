---
const items = [
  'TypeScript', 'Rust', 'Python', 'React', 'Next.js', 'Astro', 'Vue.js',
  'Three.js', 'FastAPI', 'axum', 'GraphQL', 'Solana', 'AWS', 'Terraform',
  'Kubernetes', 'Docker', 'PostgreSQL', 'LangChain', 'GSAP', 'WebGL',
];

const separator = '\u00A0\u00A0/\u00A0\u00A0';
---

<div class="relative py-16 overflow-hidden select-none" aria-hidden="true">
  <!-- Fade edges -->
  <div class="absolute left-0 top-0 bottom-0 w-24 bg-gradient-to-r from-[#020202] to-transparent z-10 pointer-events-none"></div>
  <div class="absolute right-0 top-0 bottom-0 w-24 bg-gradient-to-l from-[#020202] to-transparent z-10 pointer-events-none"></div>

  <!-- Track 1 (left) -->
  <div class="mb-4 overflow-hidden">
    <div class="marquee-track" style="--marquee-duration: 50s;">
      {[...Array(2)].map(() => (
        <span class="flex items-center gap-0 whitespace-nowrap">
          {items.map(item => (
            <span class="font-heading text-2xl md:text-4xl lg:text-5xl font-bold text-white/[0.04] tracking-tight">
              {item}{separator}
            </span>
          ))}
        </span>
      ))}
    </div>
  </div>

  <!-- Track 2 (right, reversed, serif) -->
  <div class="overflow-hidden">
    <div class="marquee-track" style="--marquee-duration: 65s; animation-direction: reverse;">
      {[...Array(2)].map(() => (
        <span class="flex items-center gap-0 whitespace-nowrap">
          {items.map(item => (
            <span class="font-serif italic text-2xl md:text-4xl lg:text-5xl font-bold text-white/[0.03] tracking-tight">
              {item}{separator}
            </span>
          ))}
        </span>
      ))}
    </div>
  </div>
</div>
