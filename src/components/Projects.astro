---
const projects = [
  {
    title: 'Immersive Gallery',
    description: 'WebGLを活用した没入型3Dギャラリー。シェーダーアニメーションとインタラクティブなカメラワークで、アート鑑賞体験を再定義。',
    tags: ['Three.js', 'GLSL', 'React'],
    color: '#00f0ff',
    image: 'linear-gradient(135deg, #0a1628 0%, #1a0a2e 50%, #0a1628 100%)',
  },
  {
    title: 'Motion Dashboard',
    description: 'リアルタイムデータをモーショングラフィックスで可視化するダッシュボード。直感的なUI/UXでデータの本質を伝える。',
    tags: ['Next.js', 'D3.js', 'Framer Motion'],
    color: '#8b5cf6',
    image: 'linear-gradient(135deg, #1a0a2e 0%, #2a0a1e 50%, #1a0a2e 100%)',
  },
  {
    title: 'AI Creative Studio',
    description: 'AIを活用したクリエイティブツール。テキストから3Dモデルやアニメーションを生成し、リアルタイムでプレビュー可能。',
    tags: ['TypeScript', 'WebGPU', 'Python'],
    color: '#f472b6',
    image: 'linear-gradient(135deg, #2a0a1e 0%, #0a1628 50%, #2a0a1e 100%)',
  },
];
---

<section id="projects" class="relative py-32 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16">
      <p class="reveal text-[#00f0ff] text-sm tracking-[0.3em] uppercase mb-4 font-heading">Projects</p>
      <h2 class="reveal reveal-delay-1 font-heading text-4xl md:text-5xl font-bold">
        Featured Works
      </h2>
    </div>

    <div class="space-y-24">
      {projects.map((project, idx) => (
        <div class={`reveal group grid md:grid-cols-2 gap-8 md:gap-12 items-center ${idx % 2 === 1 ? 'md:direction-rtl' : ''}`}>
          {/* Project visual */}
          <div class={`relative ${idx % 2 === 1 ? 'md:order-2' : ''}`}>
            <div
              class="relative aspect-[4/3] rounded-2xl overflow-hidden border border-white/5"
              style={`background: ${project.image};`}
            >
              <canvas
                class="project-canvas w-full h-full"
                data-color={project.color}
                data-index={idx}
              ></canvas>
              {/* Hover overlay */}
              <div class="absolute inset-0 bg-gradient-to-t from-[#050505]/80 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-end p-6">
                <span class="text-sm text-white/70 tracking-wider uppercase">View Project →</span>
              </div>
            </div>
          </div>

          {/* Project info */}
          <div class={`${idx % 2 === 1 ? 'md:order-1 md:text-right' : ''}`}>
            <span class="text-xs tracking-[0.2em] uppercase font-heading" style={`color: ${project.color};`}>
              Project 0{idx + 1}
            </span>
            <h3 class="font-heading text-3xl md:text-4xl font-bold mt-3 mb-4">
              {project.title}
            </h3>
            <p class="text-white/50 leading-relaxed mb-6">
              {project.description}
            </p>
            <div class={`flex flex-wrap gap-2 ${idx % 2 === 1 ? 'md:justify-end' : ''}`}>
              {project.tags.map(tag => (
                <span
                  class="px-3 py-1 text-xs rounded-full border"
                  style={`color: ${project.color}; border-color: ${project.color}30; background: ${project.color}08;`}
                >
                  {tag}
                </span>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  import * as THREE from 'three';

  function initProjectScenes() {
    const canvases = document.querySelectorAll<HTMLCanvasElement>('.project-canvas');

    canvases.forEach((canvas) => {
      const color = canvas.dataset.color ?? '#00f0ff';
      const rect = canvas.getBoundingClientRect();
      if (rect.width === 0) return;

      const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
      renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
      renderer.setSize(rect.width, rect.height);

      const scene = new THREE.Scene();
      const camera = new THREE.PerspectiveCamera(50, rect.width / rect.height, 0.1, 100);
      camera.position.z = 5;

      // Floating geometry cluster
      const group = new THREE.Group();
      scene.add(group);

      const shapes = [
        new THREE.IcosahedronGeometry(0.6, 0),
        new THREE.OctahedronGeometry(0.5, 0),
        new THREE.TetrahedronGeometry(0.4, 0),
        new THREE.BoxGeometry(0.4, 0.4, 0.4),
      ];

      for (let i = 0; i < 12; i++) {
        const geo = shapes[i % shapes.length];
        const edges = new THREE.EdgesGeometry(geo);
        const mat = new THREE.LineBasicMaterial({
          color,
          transparent: true,
          opacity: 0.2 + Math.random() * 0.3,
        });
        const line = new THREE.LineSegments(edges, mat);
        line.position.set(
          (Math.random() - 0.5) * 6,
          (Math.random() - 0.5) * 4,
          (Math.random() - 0.5) * 4,
        );
        line.rotation.set(
          Math.random() * Math.PI,
          Math.random() * Math.PI,
          Math.random() * Math.PI,
        );
        const s = 0.5 + Math.random() * 1.5;
        line.scale.setScalar(s);
        group.add(line);
      }

      // Ambient particles
      const pCount = 200;
      const pGeo = new THREE.BufferGeometry();
      const pPos = new Float32Array(pCount * 3);
      for (let i = 0; i < pCount; i++) {
        pPos[i * 3] = (Math.random() - 0.5) * 10;
        pPos[i * 3 + 1] = (Math.random() - 0.5) * 8;
        pPos[i * 3 + 2] = (Math.random() - 0.5) * 6;
      }
      pGeo.setAttribute('position', new THREE.BufferAttribute(pPos, 3));
      const pMat = new THREE.PointsMaterial({
        color,
        size: 0.03,
        transparent: true,
        opacity: 0.5,
        blending: THREE.AdditiveBlending,
      });
      const points = new THREE.Points(pGeo, pMat);
      group.add(points);

      const clock = new THREE.Clock();
      let running = true;

      function animate() {
        if (!running) return;
        requestAnimationFrame(animate);
        const elapsed = clock.getElapsedTime();

        group.rotation.y = elapsed * 0.1;
        group.rotation.x = Math.sin(elapsed * 0.2) * 0.1;

        group.children.forEach((child, i) => {
          if (child instanceof THREE.LineSegments) {
            child.rotation.x += 0.003;
            child.rotation.y += 0.002;
            child.position.y += Math.sin(elapsed + i) * 0.001;
          }
        });

        renderer.render(scene, camera);
      }

      // Lazy start: only animate when visible
      const observer = new IntersectionObserver(entries => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            if (!running) {
              running = true;
              clock.start();
              animate();
            }
          } else {
            running = false;
          }
        });
      }, { threshold: 0.1 });

      observer.observe(canvas);
      animate();

      const resizeObserver = new ResizeObserver(entries => {
        for (const entry of entries) {
          const { width, height } = entry.contentRect;
          if (width > 0 && height > 0) {
            camera.aspect = width / height;
            camera.updateProjectionMatrix();
            renderer.setSize(width, height);
          }
        }
      });
      resizeObserver.observe(canvas);
    });
  }

  initProjectScenes();
</script>
