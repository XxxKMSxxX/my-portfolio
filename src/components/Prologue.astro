---
---

<section id="prologue" class="section-fullscreen relative flex items-end pb-[10vh] md:pb-[8vh] overflow-hidden">
  <!-- Animated accent lines -->
  <div class="absolute top-0 left-[7%] w-px h-full overflow-hidden pointer-events-none">
    <div class="hero-line-v w-full h-[30vh] bg-gradient-to-b from-transparent via-white/20 to-transparent"></div>
  </div>
  <div class="absolute top-0 right-[7%] w-px h-full overflow-hidden pointer-events-none hidden md:block">
    <div class="hero-line-v w-full h-[20vh] bg-gradient-to-b from-transparent via-white/10 to-transparent" style="animation-delay: 2s;"></div>
  </div>

  <div class="relative z-10 w-full px-6 md:px-12 lg:px-[7%]">
    <!-- Role label -->
    <div class="cin-reveal flex items-center gap-3 mb-6 md:mb-8">
      <div class="w-2 h-2 rounded-full bg-[#34d399]/60 shadow-[0_0_8px_rgba(52,211,153,0.3)]"></div>
      <p class="text-xs md:text-sm tracking-[0.2em] text-white/40 font-light uppercase">
        Full-Stack Engineer <span class="text-white/25">×</span> AI Architect
      </p>
    </div>

    <!-- Name -->
    <div class="overflow-hidden">
      <h1 data-split class="font-heading text-[12vw] md:text-[8vw] lg:text-[7vw] font-semibold leading-[0.95] tracking-[-0.03em]">
        Kimura Shun
      </h1>
    </div>

    <!-- Animated gradient underline -->
    <div class="mt-4 h-px w-0 hero-underline" style="background: linear-gradient(90deg, #00f0ff40, #8b5cf640, transparent);"></div>

    <!-- Tagline — 2 lines -->
    <div class="mt-8 md:mt-10 max-w-xl space-y-2">
      <p class="mask-reveal text-base md:text-lg leading-[1.7] text-white/40 font-light">
        フロントエンドからインフラ、AI、ブロックチェーンまで——
      </p>
      <p class="mask-reveal text-base md:text-lg leading-[1.7] text-white/40 font-light">
        プロダクトを丸ごと設計・構築するエンジニア。
      </p>
    </div>

    <!-- Key numbers -->
    <div class="mt-10 md:mt-12 flex gap-10 md:gap-16 cin-reveal cin-delay-2">
      <div>
        <p class="font-heading text-2xl md:text-3xl font-light">8<span class="text-white/50">+</span></p>
        <p class="text-[10px] tracking-[0.2em] text-white/50 uppercase mt-1">Years Experience</p>
      </div>
      <div>
        <p class="font-heading text-2xl md:text-3xl font-light">15<span class="text-white/50">+</span></p>
        <p class="text-[10px] tracking-[0.2em] text-white/50 uppercase mt-1">Projects Shipped</p>
      </div>
      <div>
        <p class="font-heading text-2xl md:text-3xl font-light">57<span class="text-white/50">+</span></p>
        <p class="text-[10px] tracking-[0.2em] text-white/50 uppercase mt-1">Tech Stack</p>
      </div>
    </div>

    <!-- Bottom row -->
    <div class="mt-10 md:mt-14 flex items-center justify-between border-t border-white/[0.07] pt-6">
      <span class="text-[10px] tracking-[0.2em] text-white/25 font-light uppercase cin-reveal cin-delay-3">Tokyo, Japan</span>
      <div class="cin-reveal cin-delay-4 flex items-center gap-3">
        <span class="text-[10px] tracking-[0.2em] text-white/25 font-light">Scroll</span>
        <div class="scroll-arrow-wrap w-4 h-6 relative overflow-hidden">
          <svg class="scroll-arrow absolute w-4 h-4" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1">
            <path d="M8 1v12M3 9l5 5 5-5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-line-v {
    animation: lineSlide 4s var(--easing-smooth) infinite;
  }
  @keyframes lineSlide {
    0%   { transform: translateY(-100%); }
    100% { transform: translateY(400%); }
  }

  .hero-underline {
    animation: underlineExpand 1.8s var(--easing-smooth) 0.8s forwards;
  }
  @keyframes underlineExpand {
    to { width: min(400px, 70vw); }
  }

  .scroll-arrow {
    color: rgba(255,255,255,0.2);
    animation: scrollBounce 2s ease-in-out infinite;
  }
  @keyframes scrollBounce {
    0%, 100% { transform: translateY(-4px); opacity: 0.3; }
    50%      { transform: translateY(4px); opacity: 0.8; }
  }
</style>
