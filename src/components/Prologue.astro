---
---

<section id="prologue" class="section-fullscreen relative flex items-end pb-[12vh] md:pb-[10vh] overflow-hidden">
  <!-- Animated accent line -->
  <div class="absolute top-0 left-[7%] w-px h-full overflow-hidden pointer-events-none">
    <div class="hero-line-v w-full h-[30vh] bg-gradient-to-b from-transparent via-white/20 to-transparent"></div>
  </div>

  <div class="relative z-10 w-full px-6 md:px-12 lg:px-[7%]">
    <!-- Role -->
    <p class="cin-reveal text-xs md:text-sm tracking-[0.2em] text-white/30 font-light mb-4 md:mb-6">
      Full-Stack Engineer <span class="text-white/15">/</span> AI Architect
    </p>

    <!-- Name — large with gradient accent -->
    <div class="overflow-hidden">
      <h1 data-split class="font-heading text-[11vw] md:text-[8vw] lg:text-[7vw] font-medium leading-[1] tracking-[-0.02em]">
        Kimura Shun
      </h1>
    </div>

    <!-- Animated underline -->
    <div class="mt-3 h-px w-0 hero-underline bg-gradient-to-r from-white/40 via-white/10 to-transparent"></div>

    <!-- Tagline -->
    <div class="mt-6 md:mt-8 max-w-lg">
      <p class="mask-reveal text-sm md:text-base leading-[1.7] text-white/35 font-light">
        プロダクトの設計からインフラ構築まで、一気通貫で手がけるエンジニア。
      </p>
    </div>

    <!-- Bottom row -->
    <div class="mt-12 md:mt-16 flex items-center justify-between">
      <span class="text-[10px] tracking-[0.2em] text-white/15 font-light uppercase cin-reveal cin-delay-3">Based in Tokyo</span>
      <!-- Scroll indicator with animated arrow -->
      <div class="cin-reveal cin-delay-4 flex items-center gap-3">
        <span class="text-[10px] tracking-[0.2em] text-white/15 font-light">Scroll to explore</span>
        <div class="scroll-arrow-wrap w-4 h-6 relative overflow-hidden">
          <svg class="scroll-arrow absolute w-4 h-4" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1" class="text-white/20">
            <path d="M8 1v12M3 9l5 5 5-5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-line-v {
    animation: lineSlide 4s var(--easing-smooth) infinite;
  }
  @keyframes lineSlide {
    0%   { transform: translateY(-100%); }
    100% { transform: translateY(400%); }
  }

  .hero-underline {
    animation: underlineExpand 1.5s var(--easing-smooth) 0.8s forwards;
  }
  @keyframes underlineExpand {
    to { width: min(320px, 60vw); }
  }

  .scroll-arrow {
    color: rgba(255,255,255,0.2);
    animation: scrollBounce 2s ease-in-out infinite;
  }
  @keyframes scrollBounce {
    0%, 100% { transform: translateY(-4px); opacity: 0.3; }
    50%      { transform: translateY(4px); opacity: 0.8; }
  }
</style>
