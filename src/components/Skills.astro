---
const skills = [
  {
    category: 'Frontend',
    color: '#00f0ff',
    items: ['TypeScript', 'React', 'Next.js', 'Astro', 'Vue.js', 'Three.js'],
  },
  {
    category: 'Design',
    color: '#8b5cf6',
    items: ['Figma', 'Motion Design', 'WebGL / GLSL', 'UX Design', 'Responsive Design', 'Design Systems'],
  },
  {
    category: 'Backend',
    color: '#f472b6',
    items: ['Node.js', 'Python', 'PostgreSQL', 'GraphQL', 'Docker', 'AWS'],
  },
];
---

<section id="skills" class="relative py-32 px-6">
  <!-- Background grid -->
  <div class="absolute inset-0 opacity-[0.03]"
    style="background-image: linear-gradient(rgba(255,255,255,0.1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.1) 1px, transparent 1px); background-size: 60px 60px;">
  </div>

  <div class="relative max-w-6xl mx-auto">
    <div class="text-center mb-16">
      <p class="reveal text-[#00f0ff] text-sm tracking-[0.3em] uppercase mb-4 font-heading">Skills</p>
      <h2 class="reveal reveal-delay-1 font-heading text-4xl md:text-5xl font-bold">
        技術スタック
      </h2>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      {skills.map((skill, idx) => (
        <div class={`reveal reveal-delay-${idx + 1}`}>
          <div class="group relative p-8 rounded-2xl border border-white/5 bg-white/[0.02] hover:bg-white/[0.04] transition-all duration-500 h-full">
            <!-- Glow effect on hover -->
            <div
              class="absolute inset-0 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"
              style={`background: radial-gradient(circle at 50% 0%, ${skill.color}10, transparent 70%);`}
            ></div>

            <div class="relative">
              <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-6"
                style={`background: ${skill.color}15; border: 1px solid ${skill.color}30;`}>
                <div class="w-3 h-3 rounded-full" style={`background: ${skill.color};`}></div>
              </div>
              <h3 class="font-heading text-xl font-semibold mb-6" style={`color: ${skill.color};`}>
                {skill.category}
              </h3>
              <ul class="space-y-3">
                {skill.items.map(item => (
                  <li class="flex items-center gap-3 text-white/50 text-sm">
                    <span class="w-1 h-1 rounded-full flex-shrink-0" style={`background: ${skill.color};`}></span>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
