---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content="Kimura Shun — Full-Stack Engineer × AI Architect. Building products from frontend to infrastructure." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Space+Grotesk:wght@400;500;600;700&family=Noto+Sans+JP:wght@300;400;500;700&family=Noto+Serif+Display:ital,wght@0,400;0,700;1,400;1,700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <!-- Custom cursor -->
    <div id="cursor" class="cursor-wrap hidden md:block">
      <div id="cursor-inner">
        <span id="cursor-text" class="cursor-text"></span>
      </div>
    </div>

    <!-- Film grain -->
    <svg class="absolute w-0 h-0" aria-hidden="true">
      <filter id="grain-noise">
        <feTurbulence baseFrequency="0.65" numOctaves="3" seed="1" stitchTiles="stitch" type="fractalNoise" />
        <feColorMatrix type="saturate" values="0" />
      </filter>
    </svg>
    <div class="grain-overlay"></div>

    <!-- Progress bar (thin, top) -->
    <div class="fixed top-0 left-0 w-full z-[101] flex items-start">
      <div id="progress-bar" class="h-px bg-white/30 transition-none" style="width: 0%;"></div>
    </div>

    <!-- Chapter indicator -->
    <nav id="chapter-nav" class="fixed right-6 top-1/2 -translate-y-1/2 z-50 hidden md:flex flex-col items-end gap-4">
      <a href="#prologue" class="chapter-dot group flex items-center gap-3" data-section="prologue">
        <span class="text-[10px] tracking-[0.2em] uppercase text-white/0 group-hover:text-white/40 transition-all duration-500">Top</span>
        <span class="block w-1.5 h-1.5 rounded-full bg-white/15 transition-all duration-500"></span>
      </a>
      <a href="#about" class="chapter-dot group flex items-center gap-3" data-section="about">
        <span class="text-[10px] tracking-[0.2em] uppercase text-white/0 group-hover:text-white/40 transition-all duration-500">About</span>
        <span class="block w-1.5 h-1.5 rounded-full bg-white/15 transition-all duration-500"></span>
      </a>
      <a href="#skills" class="chapter-dot group flex items-center gap-3" data-section="skills">
        <span class="text-[10px] tracking-[0.2em] uppercase text-white/0 group-hover:text-white/40 transition-all duration-500">Skills</span>
        <span class="block w-1.5 h-1.5 rounded-full bg-white/15 transition-all duration-500"></span>
      </a>
      <a href="#architecture" class="chapter-dot group flex items-center gap-3" data-section="architecture">
        <span class="text-[10px] tracking-[0.2em] uppercase text-white/0 group-hover:text-white/40 transition-all duration-500">Arch</span>
        <span class="block w-1.5 h-1.5 rounded-full bg-white/15 transition-all duration-500"></span>
      </a>
      <a href="#projects" class="chapter-dot group flex items-center gap-3" data-section="projects">
        <span class="text-[10px] tracking-[0.2em] uppercase text-white/0 group-hover:text-white/40 transition-all duration-500">Works</span>
        <span class="block w-1.5 h-1.5 rounded-full bg-white/15 transition-all duration-500"></span>
      </a>
      <a href="#epilogue" class="chapter-dot group flex items-center gap-3" data-section="epilogue">
        <span class="text-[10px] tracking-[0.2em] uppercase text-white/0 group-hover:text-white/40 transition-all duration-500">Contact</span>
        <span class="block w-1.5 h-1.5 rounded-full bg-white/15 transition-all duration-500"></span>
      </a>
    </nav>

    <slot />
  </body>
</html>

<style is:global>
  * { margin: 0; padding: 0; box-sizing: border-box; }

  :root {
    --color-main: #000000;
    --color-sub: #ffffff;
    --color-gray: #666666;
    --easing-smooth: cubic-bezier(.07, .84, .26, 1);
    --easing-out: cubic-bezier(.46, 0, .17, 1);
    --duration-normal: 0.8s;
  }

  html {
    scroll-behavior: auto;
    font-feature-settings: "palt" 1;
  }

  body {
    background: var(--color-main);
    color: var(--color-sub);
    font-family: 'Inter', 'Noto Sans JP', sans-serif;
    font-weight: 300;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    overflow-x: hidden;
    cursor: none;
  }

  @media (max-width: 768px) {
    body { cursor: auto; }
  }

  ::selection {
    background: rgba(255, 255, 255, 0.15);
    color: #fff;
  }

  ::-webkit-scrollbar { width: 0; }

  .font-heading { font-family: 'Space Grotesk', 'Noto Sans JP', sans-serif; }
  .font-serif { font-family: 'Noto Serif Display', 'Noto Sans JP', serif; }

  /* ---- Full-screen section ---- */
  .section-fullscreen {
    min-height: 100vh;
    min-height: 100dvh;
    width: 100%;
    position: relative;
  }

  /* ---- Custom cursor (glass morphism) ---- */
  .cursor-wrap {
    position: fixed;
    top: 0;
    left: 0;
    pointer-events: none;
    z-index: 100000;
  }

  #cursor-inner {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    transform: translate(-50%, -50%) scale(0);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.6s var(--easing-smooth),
                width 0.4s var(--easing-smooth),
                height 0.4s var(--easing-smooth);
    overflow: hidden;
    position: relative;
  }

  #cursor-inner::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.06);
    backdrop-filter: blur(15px);
    -webkit-backdrop-filter: blur(15px);
    z-index: 1;
  }

  #cursor-inner::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: rgba(0, 0, 0, 0.1);
    z-index: 0;
  }

  .cursor-text {
    position: relative;
    z-index: 2;
    font-size: 10px;
    letter-spacing: 0.05em;
    color: var(--color-sub);
    transition: opacity 0.3s;
    opacity: 0;
  }

  .cursor-wrap.visible #cursor-inner {
    transform: translate(-50%, -50%) scale(1);
  }

  .cursor-wrap.hovering #cursor-inner {
    width: 80px;
    height: 80px;
  }

  .cursor-wrap.hovering .cursor-text {
    opacity: 1;
  }

  /* ---- Cinematic reveals ---- */
  /* JS adds .js-ready to html; without JS everything is visible */
  html.js-ready .cin-reveal {
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 1s var(--easing-smooth),
                transform 1s var(--easing-smooth);
  }
  html.js-ready .cin-reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }
  .cin-delay-1 { transition-delay: 0.15s; }
  .cin-delay-2 { transition-delay: 0.3s; }
  .cin-delay-3 { transition-delay: 0.45s; }
  .cin-delay-4 { transition-delay: 0.6s; }
  .cin-delay-5 { transition-delay: 0.75s; }

  /* ---- Split text line reveal ---- */
  .text-split-line {
    overflow: hidden;
    display: block;
    position: relative;
  }
  .text-split-line-inner {
    display: block;
    transform: translateY(100%);
    transition: transform 0.8s var(--easing-smooth);
  }
  .text-split-line-inner.visible {
    transform: translateY(0);
  }

  /* ---- Split chars ---- */
  html.js-ready .split-char {
    display: inline-block;
    opacity: 0;
    transform: translateY(100%);
    will-change: transform, opacity;
  }
  html.js-ready .split-char.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ---- Mask text reveal (horizontal wipe) ---- */
  html.js-ready .mask-reveal {
    --reveal: 0;
    -webkit-mask-image: linear-gradient(to right, #000 0%, #000 100%);
    mask-image: linear-gradient(to right, #000 0%, #000 100%);
    -webkit-mask-size: calc(var(--reveal) * 100%) 100%;
    mask-size: calc(var(--reveal) * 100%) 100%;
    -webkit-mask-repeat: no-repeat;
    mask-repeat: no-repeat;
  }

  /* ---- Film grain ---- */
  .grain-overlay {
    position: fixed;
    inset: -50%;
    width: 200%;
    height: 200%;
    filter: url(#grain-noise);
    opacity: 0.025;
    mix-blend-mode: overlay;
    pointer-events: none;
    z-index: 9998;
    animation: grainDrift 0.4s steps(8) infinite;
  }

  @keyframes grainDrift {
    0%   { transform: translate(0, 0); }
    12%  { transform: translate(-2%, -3%); }
    25%  { transform: translate(3%, 1%); }
    37%  { transform: translate(-1%, 2%); }
    50%  { transform: translate(2%, -1%); }
    62%  { transform: translate(-3%, 3%); }
    75%  { transform: translate(1%, -2%); }
    87%  { transform: translate(-2%, 1%); }
    100% { transform: translate(0, 0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .grain-overlay { animation: none; opacity: 0.015; }
  }

  /* ---- Active chapter dot ---- */
  .chapter-dot.active span:last-child {
    background: var(--color-sub) !important;
    width: 0.5rem;
    height: 0.5rem;
  }
  .chapter-dot.active span:first-child {
    color: rgba(255, 255, 255, 0.4) !important;
  }

  /* ---- Marquee ---- */
  @keyframes marqueeScroll {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }
  .marquee-track {
    display: flex;
    width: max-content;
    animation: marqueeScroll var(--marquee-duration, 40s) linear infinite;
  }
  .marquee-track:hover {
    animation-play-state: paused;
  }

  /* ---- Lenis ---- */
  html.lenis, html.lenis body { height: auto; }
  .lenis.lenis-smooth { scroll-behavior: auto !important; }

  /* ---- Loading state ---- */
  html.js-ready body:not(.loaded) main { opacity: 0; }
  body.loaded main {
    opacity: 1;
    transition: opacity 0.8s var(--easing-smooth) 0.1s;
  }

  /* ---- Horizontal line reveal ---- */
  .line-h {
    height: 0.5px;
    background: var(--color-sub);
    opacity: 0.08;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 1.2s var(--easing-smooth);
  }
  .line-h.visible {
    transform: scaleX(1);
  }
</style>

<script>
  // Mark JS as ready — without this, all reveal elements stay visible (CSS fallback)
  document.documentElement.classList.add('js-ready');

  // Safety net: if loaded class isn't added within 5s, force everything visible
  setTimeout(() => {
    if (!document.body.classList.contains('loaded')) {
      document.body.classList.add('loaded');
      document.querySelectorAll('.cin-reveal').forEach(el => el.classList.add('visible'));
      document.querySelectorAll('.mask-reveal').forEach(el => {
        (el as HTMLElement).style.setProperty('--reveal', '1');
      });
    }
  }, 5000);

  import Lenis from 'lenis';
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // ---- Lenis smooth scroll ----
  const lenis = new Lenis({
    duration: 1.2,
    easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
    touchMultiplier: 2,
  });

  lenis.on('scroll', ScrollTrigger.update);
  gsap.ticker.add((time) => { lenis.raf(time * 1000); });
  gsap.ticker.lagSmoothing(0);

  // ---- Custom cursor (glass morphism) ----
  const cursor = document.getElementById('cursor');
  let mx = 0, my = 0, cx = 0, cy = 0;

  document.addEventListener('mousemove', (e) => {
    mx = e.clientX;
    my = e.clientY;
    cursor?.classList.add('visible');
  });

  function animateCursor() {
    cx += (mx - cx) * 0.1;
    cy += (my - cy) * 0.1;
    if (cursor) cursor.style.transform = `translate(${cx}px, ${cy}px)`;
    requestAnimationFrame(animateCursor);
  }
  animateCursor();

  const cursorText = document.getElementById('cursor-text');
  document.querySelectorAll('a, button, [data-cursor-hover]').forEach(el => {
    el.addEventListener('mouseenter', () => {
      cursor?.classList.add('hovering');
      const label = (el as HTMLElement).dataset.mouseTarget;
      if (cursorText && label) cursorText.textContent = label;
      else if (cursorText) cursorText.textContent = '+';
    });
    el.addEventListener('mouseleave', () => {
      cursor?.classList.remove('hovering');
      if (cursorText) cursorText.textContent = '';
    });
  });

  // ---- Progress bar ----
  const progressBar = document.getElementById('progress-bar');
  window.addEventListener('scroll', () => {
    const scrollTop = window.scrollY;
    const docHeight = document.documentElement.scrollHeight - window.innerHeight;
    const progress = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
    if (progressBar) progressBar.style.width = `${progress}%`;
  });

  // ---- Chapter nav active state ----
  const sections = document.querySelectorAll('section[id]');
  const dots = document.querySelectorAll('.chapter-dot');

  const navObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const id = entry.target.id;
        dots.forEach(d => {
          d.classList.toggle('active', d.getAttribute('data-section') === id);
        });
      }
    });
  }, { threshold: 0.3 });

  sections.forEach(s => navObserver.observe(s));

  // ---- Cinematic reveal observer ----
  const revealObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) entry.target.classList.add('visible');
    });
  }, { threshold: 0.05, rootMargin: '0px 0px -30px 0px' });

  function observeReveals() {
    document.querySelectorAll('.cin-reveal, .line-h, .text-split-line-inner').forEach(el => {
      revealObserver.observe(el);
    });
  }
  observeReveals();

  // Re-observe after loading completes to catch elements already in viewport
  const loadedCheck = setInterval(() => {
    if (document.body.classList.contains('loaded')) {
      clearInterval(loadedCheck);
      // Force re-evaluation by unobserving and re-observing
      document.querySelectorAll('.cin-reveal, .line-h, .text-split-line-inner').forEach(el => {
        revealObserver.unobserve(el);
        revealObserver.observe(el);
      });
    }
  }, 100);

  // ---- Split text (GSAP) ----
  document.querySelectorAll('[data-split]').forEach(el => {
    const text = el.textContent ?? '';
    el.innerHTML = '';
    const chars: HTMLSpanElement[] = [];
    text.split('').forEach((char) => {
      const span = document.createElement('span');
      span.className = 'split-char';
      span.textContent = char === ' ' ? '\u00A0' : char;
      el.appendChild(span);
      chars.push(span);
    });

    gsap.to(chars, {
      opacity: 1,
      y: 0,
      duration: 0.8,
      stagger: 0.03,
      ease: 'power3.out',
      scrollTrigger: {
        trigger: el,
        start: 'top 85%',
        toggleActions: 'play none none none',
      },
    });
  });

  // ---- Mask reveal ----
  document.querySelectorAll('.mask-reveal').forEach(el => {
    const rect = el.getBoundingClientRect();
    const isAboveFold = rect.top < window.innerHeight;

    if (isAboveFold) {
      // Already in viewport — reveal immediately without scrub
      (el as HTMLElement).style.setProperty('--reveal', '1');
    } else {
      gsap.to(el as HTMLElement, {
        '--reveal': 1,
        ease: 'none',
        scrollTrigger: {
          trigger: el,
          start: 'top 85%',
          end: 'top 40%',
          scrub: 0.8,
        },
      });
    }
  });

  // ---- Stagger reveal for grid items ----
  document.querySelectorAll('[data-stagger-parent]').forEach(parent => {
    const children = parent.querySelectorAll('[data-stagger-child]');
    gsap.from(children, {
      y: 60,
      opacity: 0,
      duration: 0.8,
      stagger: 0.06,
      ease: 'power3.out',
      scrollTrigger: {
        trigger: parent,
        start: 'top 80%',
        toggleActions: 'play none none none',
      },
    });
  });

  // ---- SVG circles parallax ----
  document.querySelectorAll('.svg-circles svg').forEach((svg, i) => {
    gsap.to(svg, {
      y: () => (i % 2 === 0 ? -80 : 80),
      rotation: i * 15,
      ease: 'none',
      scrollTrigger: {
        start: 0,
        end: 'max',
        scrub: 1,
      },
    });
  });
</script>
